---
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import logo from "../assets/prysmnexus-logo-mark-hq-transparent.png";
import { brand, services } from "../data/seo";
import "../styles/seo-pages.css";

interface Props {
  title: string;
  description: string;
  eyebrow: string;
  heading: string;
  lead: string;
  schemas?: Record<string, unknown>[];
  type?: "website" | "article";
  published?: string;
  modified?: string;
  noindex?: boolean;
}

const { title, description, eyebrow, heading, lead, schemas = [], type = "website", published, modified, noindex = false } = Astro.props;
const segments = Astro.url.pathname.split("/").filter(Boolean);
const contextualBackLink = segments[0] === "services"
  ? segments.length > 1
    ? { href: "/services/", label: "Back to Services", ariaLabel: "Back to all services" }
    : { href: "/", label: "Back to Home", ariaLabel: "Back to home" }
  : segments[0] === "case-studies"
    ? segments.length > 1
      ? { href: "/case-studies/", label: "Back to Case Studies", ariaLabel: "Back to all case studies" }
      : { href: "/", label: "Back to Home", ariaLabel: "Back to home" }
    : null;
---

<BaseLayout title={title} description={description} schemas={schemas} type={type} published={published} modified={modified} noindex={noindex}>
  <div class="seoPage">
    <header class="seoHeader">
      <a class="seoLogo" href="/" aria-label="PrysmNexus home">
        <span class="seoLogoMark"><Image src={logo} alt="" widths={[96, 144, 192, 256]} sizes="54px" format="webp" quality={100} loading="eager" /></span>
        <span class="brandWordmark"><svg xmlns="http://www.w3.org/2000/svg" viewBox="518 576 744 278" fill="none">
