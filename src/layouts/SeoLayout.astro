      <button class="seoMenuButton" type="button" aria-label="Open navigation" aria-expanded="false" aria-controls="seo-primary-nav">
        <span aria-hidden="true"></span><span aria-hidden="true"></span><span aria-hidden="true"></span>
      </button>
      <nav class="seoNav" id="seo-primary-nav" aria-label="Primary navigation">
        <a href="/">Home</a><a href="/services/">Services</a><a href="/case-studies/">Our Works</a><a href="/insights/">Insights</a><a href="/about/">About</a><a href="/contact/">Contact</a><a class="seoCta" href="/contact/#consultation-form">Free Consultation</a>
      </nav>
    </header>
    <div class="seoNavBackdrop" aria-hidden="true"></div>
    <main id="main-content">
      <section class="seoHero">
        <div class="seoHeroInner">
          {contextualBackLink && (
            <a class="seoBackLink" href={contextualBackLink.href} aria-label={contextualBackLink.ariaLabel}>
              <span aria-hidden="true">←</span> {contextualBackLink.label}
            </a>
          )}
          <nav class="seoBreadcrumbs" aria-label="Breadcrumb"><a href="/">Home</a>{segments.map((segment, index) => <><span>/</span>{index === segments.length - 1 ? <span aria-current="page">{segment.replaceAll("-", " ")}</span> : <a href={`/${segments.slice(0, index + 1).join("/")}/`}>{segment.replaceAll("-", " ")}</a>}</>)}</nav>
          <div class="seoEyebrow">{eyebrow}</div>
          <h1>{heading}</h1>
          <p class="seoHeroLead">{lead}</p>
          <div class="seoHeroActions"><a class="seoButton" href="/contact/#consultation-form">Discuss your goals <span aria-hidden="true">↗</span></a><a class="seoButton secondary" href="/services/">Explore services</a></div>
          {type === "article" && <div class="articleMeta"><span>By PrysmNexus Strategy Team</span><span>Updated {modified}</span><span>India</span></div>}
        </div>
      </section>
      <slot />
    </main>
    <footer class="seoFooter">
      <div class="seoFooterTop">
        <div><h2>Growth, automation, and software. One accountable team.</h2><p>{brand.description}</p><a class="seoButton" href={`mailto:${brand.email}`}>{brand.email}</a></div>
        <nav><strong>Services</strong>{services.map((service) => <a href={`/services/${service.slug}/`}>{service.shortName}</a>)}</nav>
        <nav><strong>Explore</strong><a href="/case-studies/">Case Studies</a><a href="/insights/digital-marketing-services-india/">Digital Marketing Services</a><a href="/insights/">Insights</a><a href="/about/">About</a><a href="/contact/">Contact</a><a href="/privacy/">Privacy</a><a href="/cookie-policy/">Cookie Policy</a></nav>
      </div>
      <div class="seoFooterBottom">© 2026 PrysmNexus · Serving businesses across India</div>
    </footer>
  </div>
  <script>
    const menuButton = document.querySelector<HTMLButtonElement>(".seoMenuButton");
    const navigation = document.querySelector<HTMLElement>("#seo-primary-nav");
    const backdrop = document.querySelector<HTMLElement>(".seoNavBackdrop");
    const setMenuOpen = (open: boolean) => {
      menuButton?.setAttribute("aria-expanded", String(open));
      menuButton?.setAttribute("aria-label", open ? "Close navigation" : "Open navigation");
      navigation?.classList.toggle("is-open", open);
      backdrop?.classList.toggle("is-open", open);
      document.documentElement.classList.toggle("seo-menu-open", open);
    };
    menuButton?.addEventListener("click", () => setMenuOpen(menuButton.getAttribute("aria-expanded") !== "true"));
    backdrop?.addEventListener("click", () => setMenuOpen(false));
    navigation?.querySelectorAll("a").forEach((link) => link.addEventListener("click", () => setMenuOpen(false)));
    addEventListener("keydown", (event) => {
      if (event.key === "Escape" && menuButton?.getAttribute("aria-expanded") === "true") {
        setMenuOpen(false);
        menuButton.focus();
      }
    });
    addEventListener("resize", () => {
      if (innerWidth > 820) setMenuOpen(false);
    }, { passive: true });
  </script>
</BaseLayout>
