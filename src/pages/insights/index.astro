---
import SeoLayout from "../../layouts/SeoLayout.astro";
import { brand, breadcrumbSchema, insights } from "../../data/seo";
const origin = (Astro.site ?? new URL(brand.domain)).origin;
const schemas = [breadcrumbSchema(origin, [{ name: "Home", path: "/" }, { name: "Insights", path: "/insights/" }])];
---
<SeoLayout title="Marketing Insights for Hyderabad Businesses | PrysmNexus" description="Practical guides to restaurant marketing, local SEO, Google Business Profile, paid advertising, and social content from PrysmNexus." eyebrow="Useful marketing guidance" heading="Clear answers for Hyderabad brands building sustainable visibility." lead="Original guidance from the PrysmNexus Strategy Team, structured around the questions local businesses ask before investing in content, campaigns, and search." schemas={schemas}>
  <div class="seoMain"><aside class="answerBlock"><span>Editorial standard</span><p>PrysmNexus Insights explains the reasoning, process, limitations, and measurement behind practical marketing decisions. Articles are reviewed for clarity and updated when guidance or business context changes.</p></aside><div class="seoIndexGrid">{insights.map((article) => <a class="seoIndexCard" href={`/insights/${article.slug}/`}><small>Updated {article.updated}</small><div><h2>{article.title}</h2><p>{article.description}</p></div><strong>Read insight ↗</strong></a>)}</div></div>
</SeoLayout>
