---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import aboutImage from "../assets/about.jpg";
import serviceImage from "../assets/service.webp";
import heroImage from "../assets/hero.png";
import processBackdrop from "../assets/bg-step-overly.png";
import whyAnalyticsImage from "../assets/why-analytics.jpg";
import whyFeatureImage from "../assets/why-feature.jpg";
import whyTeamImage from "../assets/why-team.jpg";
import whySupportImage from "../assets/why-support.jpg";
import projectBrandImage from "../assets/project-brand.jpg";
import projectSocialImage from "../assets/project-social.jpg";
import projectContentImage from "../assets/project-content.jpg";

const services = [
  { number: "01", title: "Brand Strategy & Identity", description: "Clear positioning, voice, and visual direction that make your business recognizable and consistent across every customer touchpoint.", bullets: ["Brand positioning", "Visual direction", "Messaging framework", "Campaign toolkit"] },
  { number: "02", title: "Content Production", description: "Original photography, video, reels, and campaign creatives planned around your brand rather than recycled templates.", bullets: ["Photography and video", "Reels and short-form content", "Creative copy", "Campaign design"] },
  { number: "03", title: "Social Media Management", description: "A practical content system that keeps your channels active, consistent, and focused on meaningful audience engagement.", bullets: ["Content calendar", "Publishing and page handling", "Community engagement", "Monthly reporting"] },
  { number: "04", title: "Performance Marketing", description: "Focused Google and Meta campaigns designed to generate qualified enquiries with clear tracking and accountable optimization.", bullets: ["Google and Meta ads", "Lead generation", "Landing-page alignment", "Campaign reporting"] },
  { number: "05", title: "SEO, Local & Reputation", description: "Search, Google Business Profile, and reputation improvements that help nearby customers find and trust your business.", bullets: ["SEO and local search", "Google Business Profile", "Review management", "Search visibility reporting"] },
];

const projectStudies = [
  { image: projectBrandImage, category: "Brand / Strategy", title: "Brand Identity Transformation", copy: "A sharper visual and messaging system built for consistent recognition across every channel.", result: "Stronger brand recall", accent: "#e45d5e" },
  { image: projectSocialImage, category: "Social / Content", title: "Always-On Content Engine", copy: "A practical publishing system that turned scattered activity into clear, consistent audience growth.", result: "Higher engagement", accent: "#ef8d48" },
  { image: whyAnalyticsImage, category: "Performance / Media", title: "Qualified Lead Campaign", copy: "Focused creative, audience testing, and accountable optimization designed around meaningful enquiries.", result: "Better lead quality", accent: "#d9353a" },
  { image: projectContentImage, category: "Creative / Production", title: "Campaign Content Studio", copy: "Original campaign visuals and short-form assets designed to keep the brand fresh and recognizable.", result: "Faster production", accent: "#e77248" },
  { image: whyTeamImage, category: "Integrated / Growth", title: "Connected Growth Programme", copy: "Strategy, content, paid media, and search aligned under one focused plan and reporting rhythm.", result: "One accountable team", accent: "#cc3f46" },
];

const workProcessSteps = [
  { number: "01", glyph: "◎", title: "Discover", copy: "We assess your goals, audience, current channels, and market position to understand what the business needs most." },
  { number: "02", glyph: "≋", title: "Analyze", copy: "We examine brand, content, campaign, and search performance to uncover gaps and practical opportunities." },
  { number: "03", glyph: "◇", title: "Strategize", copy: "We shape a connected, actionable growth plan aligned with your priorities, resources, and commercial goals." },
  { number: "04", glyph: "↗", title: "Execute & Optimize", copy: "We launch, measure, learn, and continuously improve the work to build sustainable momentum." },
];

const faqs = [
  { question: "What does PrysmNexus handle?", answer: "PrysmNexus brings brand strategy, content production, social media, paid advertising, SEO, local search, and reputation support under one accountable team." },
  { question: "Do you produce original content?", answer: "Yes. Content can include photography, video, reels, campaign creatives, and copy developed around your brand, audience, and business goals." },
  { question: "Can you manage Google and Meta advertising?", answer: "Yes. Campaign work can cover account setup, audience and creative planning, lead generation, conversion paths, optimization, and reporting." },
  { question: "How do you improve local visibility?", answer: "We combine local SEO, Google Business Profile improvements, useful website content, and reputation management to strengthen discovery and trust." },
  { question: "Do you offer fixed packages?", answer: "Scope is tailored to the channels, content volume, campaign needs, and level of ongoing support required. Recommendations are made after a focused discovery review." },
  { question: "How is performance measured?", answer: "We agree on relevant baselines and report against practical signals such as reach, engagement, qualified leads, search visibility, profile actions, and conversions." },
];

const siteUrl = (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, "");
const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${siteUrl}/#organization`,
    name: "PrysmNexus",
    url: `${siteUrl}/`,
    logo: `${siteUrl}/prysmnexus-logo.png`,
    description: "PrysmNexus is a Hyderabad-based growth marketing agency combining branding, content production, social media, paid acquisition, SEO, local search, and reputation support.",
    email: "hello@prysmnexus.agency",
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${siteUrl}/#website`,
    url: `${siteUrl}/`,
    name: "PrysmNexus",
    publisher: { "@id": `${siteUrl}/#organization` },
    inLanguage: "en",
  },
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "@id": `${siteUrl}/#service`,
    name: "PrysmNexus Growth Marketing",
    url: `${siteUrl}/`,
    provider: { "@id": `${siteUrl}/#organization` },
    serviceType: ["Brand Strategy", "Content Production", "Social Media Management", "Performance Marketing", "Search Engine Optimization", "Local Search Optimization", "Reputation Management"],
    areaServed: "Hyderabad, India",
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map(({ question, answer }) => ({
      "@type": "Question",
      name: question,
      acceptedAnswer: { "@type": "Answer", text: answer },
    })),
  },
];
---

<BaseLayout
  title="PrysmNexus — Branding & Growth Marketing Agency in Hyderabad"
  description="PrysmNexus combines brand strategy, original content, social media, performance marketing, SEO, local search, and reputation support under one accountable team."
  schemas={schemas}
>
  <div class="scrollProgress" aria-hidden="true"><span></span></div>
  <div class="cursorHalo" aria-hidden="true"></div>
  <main id="main-content">
    <section class="hero" id="home" aria-labelledby="hero-heading">
      <canvas class="prismCanvas" aria-hidden="true"></canvas>
      <div class="prismField" aria-hidden="true"><i></i><i></i><i></i><i></i></div>
      <header class="siteHeader" data-site-header>
        <a class="logo" href="#home" aria-label="PrysmNexus home" translate="no">
          <span class="brandLogo"><img src="/prysmnexus-logo.png" alt="" width="1254" height="1254" /></span>
          <span><b>Prysm<span>Nexus</span></b><small>GROWTH MARKETING</small></span>
        </a>
        <button class="menuButton" type="button" aria-label="Toggle navigation" aria-expanded="false" aria-controls="primary-nav">☰</button>
        <nav id="primary-nav" aria-label="Primary navigation">
          <a href="#home">Home</a><a href="#services">Services</a><a href="#about">About</a><a href="#method">Method</a><a href="#faq">FAQ</a><a href="#contact">Contact</a>
        </nav>
        <div class="headerActions"><span class="dash"></span><a class="consult" href="#contact">Free Consultation</a><span class="gridButton" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i></span></div>
      </header>
      <div class="heroGlow"></div>
      <h1 class="heroTitle" id="hero-heading"><span class="heroWord"><em>Growth</em></span><strong class="heroWord"><em>Marketing</em></strong><small>Built Around Your Business.</small></h1>
      <div class="focused" aria-hidden="true"><span>Focused</span></div>
      <div class="heroCopy" data-reveal="up">
        <p><strong>PrysmNexus is a Hyderabad-based growth marketing agency</strong> bringing brand strategy, original content, social media, paid campaigns, and search visibility together under one accountable team.</p>
        <a class="gradientButton" href="#services">Explore Services <b>↗</b></a>
      </div>
    </section>

    <section class="capabilityShowcase" aria-label="Core marketing capabilities">
      <div class="capabilityPanel">
        {[
          ["Performance Marketing", "Focused Google and Meta campaigns built to generate qualified enquiries.", "↗", "4.8%"],
          ["Brand & Content Strategy", "Clear positioning and original content shaped around your audience.", "✦", "35%"],
          ["One Accountable Team", "Strategy, creative, publishing, and optimization managed together.", "◎", "65.2%"],
          ["SEO & Local Growth", "Stronger search, Google profile, and reputation signals for discovery.", "⌕", "95.3%"],
        ].map(([title, text, glyph, photoPosition], index) => (
          <article class="capabilityCard" data-reveal="up" style={`--reveal-delay:${index * 100}ms;--photo-x:${photoPosition}`}>
            <div class="capabilityPhoto" aria-hidden="true"><span></span></div>
            <span class="capabilityIcon" aria-hidden="true"><b>{glyph}</b></span>
            <h2>{title}</h2>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="about" id="about">
      <div class="aboutShowcase">
        <div class="aboutVisual" data-reveal="clip"><Image src={aboutImage} alt="Marketing team collaborating around a tablet" widths={[560, 760, 960, 1200]} sizes="(max-width: 760px) 100vw, (max-width: 1100px) 40vw, 636px" format="webp" quality={92} loading="lazy" /></div>
        <div class="aboutContent">
          <div class="eyebrow" data-reveal="line">About Us</div>
          <h2 data-reveal="title">We help brands grow faster with powerful digital marketing strategies.</h2>
          <div class="aboutMetrics" data-reveal="up">
            <article class="experienceMetric">
              <img class="metricMark" src="/prysmnexus-logo.png" alt="" width="1254" height="1254" loading="lazy" />
              <strong data-count="30" data-suffix="+">0</strong>
              <span>Years Of Working<br />Experience</span>
            </article>
            <article class="wide loyaltyMetric">
              <Image class="metricBackdrop" src={serviceImage} alt="" widths={[520, 760]} sizes="(max-width: 760px) 100vw, 34vw" format="webp" quality={72} loading="lazy" />
              <strong data-count="28" data-suffix="M">0</strong>
              <div class="metricAvatars" aria-hidden="true">
                <Image src={aboutImage} alt="" width={42} height={42} format="webp" quality={70} loading="lazy" />
                <Image src={serviceImage} alt="" width={42} height={42} format="webp" quality={70} loading="lazy" />
                <Image src={aboutImage} alt="" width={42} height={42} format="webp" quality={70} loading="lazy" />
                <Image src={serviceImage} alt="" width={42} height={42} format="webp" quality={70} loading="lazy" />
              </div>
              <span>Customer Happiness and Loyalty</span>
            </article>
          </div>
          <div class="mission aboutMission" data-reveal="up">
            <Image class="missionBackdrop" src={serviceImage} alt="" widths={[640, 900]} sizes="(max-width: 760px) 100vw, 48vw" format="webp" quality={66} loading="lazy" />
            <div class="tabs" role="tablist" aria-label="About PrysmNexus">
              <button class="active" id="about-tab-mission" type="button" role="tab" aria-selected="true" aria-controls="about-panel" tabindex="0" data-mission-tab="0">Our Mission</button>
              <button id="about-tab-vision" type="button" role="tab" aria-selected="false" aria-controls="about-panel" tabindex="-1" data-mission-tab="1">Our Vision</button>
              <button id="about-tab-goal" type="button" role="tab" aria-selected="false" aria-controls="about-panel" tabindex="-1" data-mission-tab="2">Our Goal</button>
            </div>
            <div class="missionCopy" id="about-panel" role="tabpanel" aria-labelledby="about-tab-mission" aria-live="polite" tabindex="0" data-mission-copy><p>Our mission is to empower businesses with clear strategies, data-driven insights, and practical solutions that drive sustainable growth, improve performance, and create lasting value in an ever-changing competitive market.</p></div>
          </div>
          <p class="aboutSummary" data-reveal="up">PrysmNexus brings strategy, creativity, and analytics together so your brand, content, campaigns, and search presence move in the same direction.</p>
          <a class="gradientButton magnetic" href="#services" data-reveal="up">Know About Us <b>↗</b></a>
        </div>
      </div>
    </section>

    <section class="reviews" aria-label="Working principles"><div class="reviewTrack">{[0, 1].map((set) => <div class="reviewSet" aria-hidden={set === 1 ? "true" : undefined}><div><span>“Make the brand clear.”</span><b>POSITIONING</b></div><div><span>“Create, do not recycle.”</span><b>ORIGINALITY</b></div><div><span>“Connect every channel.”</span><b>CONSISTENCY</b></div><div><span>“Measure what matters.”</span><b>ACCOUNTABILITY</b></div></div>)}</div></section>

    <section class="services servicesShowcase" id="services">
      <div class="servicesAura" aria-hidden="true"></div>
      <header class="servicesHeader">
        <div>
          <div class="eyebrow light" data-reveal="line">What We Do</div>
          <h2 data-reveal="title">One team.<br /><span>Every growth lever.</span></h2>
        </div>
        <div class="servicesLead" data-reveal="up">
          <p>Strategy, creative, media, and search—designed as one connected system that moves your brand forward.</p>
          <a href="#contact">Build your growth system <span aria-hidden="true">↗</span></a>
        </div>
      </header>

      <div class="serviceBento">
        {services.map((service, index) => (
          <article class:list={["serviceCard", index === 0 && "serviceCardFeatured"]} data-reveal="up" style={`--reveal-delay:${index * 70}ms`}>
            <div class="serviceCardTop">
              <span class="serviceNumber">{service.number}</span>
              <span class="serviceArrow" aria-hidden="true">↗</span>
            </div>
            {index === 0 && (
              <div class="serviceBrandMark" aria-hidden="true">
                <span></span><span></span><span></span>
                <img src="/prysmnexus-logo.png" alt="" width="1254" height="1254" />
              </div>
            )}
            <div class="serviceCardBody">
              <h3>{service.title}</h3>
              <p>{service.description}</p>
              <ul aria-label={`${service.title} capabilities`}>
                {service.bullets.slice(0, index === 0 ? 4 : 2).map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="whyChoose" id="method" aria-labelledby="why-choose-title">
      <header class="whyChooseHeader">
        <div>
          <div class="eyebrow" data-reveal="line">Why Choose Us</div>
          <h2 id="why-choose-title" data-reveal="title">Flexible growth support<br />tailored to your business.</h2>
        </div>
        <p data-reveal="up">We combine strategic insight, original execution, and accountable support to build sustainable growth and long-term momentum.</p>
      </header>

      <div class="whyChooseLayout">
        <div class="whyChooseBento">
          <article class="whyCard whyCapabilities" data-reveal="up">
            <h3>Capabilities We Bring</h3>
            <div class="whyRibbon" aria-label="PrysmNexus capabilities">
              <div class="whyRibbonRow">
                <span>Brand Strategy</span><span>Content Production</span><span>Social Media</span><span>Performance Marketing</span><span>SEO</span><span>Local Search</span><span>Brand Strategy</span><span>Content Production</span><span>Social Media</span><span>Performance Marketing</span><span>SEO</span><span>Local Search</span>
              </div>
              <div class="whyRibbonRow reverse">
                <span>Reputation</span><span>Campaign Creative</span><span>Lead Journeys</span><span>Analytics</span><span>Messaging</span><span>Video</span><span>Reputation</span><span>Campaign Creative</span><span>Lead Journeys</span><span>Analytics</span><span>Messaging</span><span>Video</span>
              </div>
              <div class="whyRibbonRow">
                <span>Google Ads</span><span>Meta Ads</span><span>Conversion</span><span>Community</span><span>Reporting</span><span>Identity</span><span>Google Ads</span><span>Meta Ads</span><span>Conversion</span><span>Community</span><span>Reporting</span><span>Identity</span>
              </div>
            </div>
          </article>

          <article class="whyCard whyProjects" data-reveal="up" style="--reveal-delay:70ms">
            <div class="whyProjectVisual">
              <Image src={whyAnalyticsImage} alt="Marketing analytics displayed on a laptop" widths={[520, 760, 1040]} sizes="(max-width: 820px) 100vw, 30vw" format="webp" quality={92} loading="lazy" />
              <div><strong data-count="500" data-suffix="+">0</strong><span>Campaigns delivered</span></div>
            </div>
            <div class="whyProjectCta"><p>Let’s make great work together.<br /><a href="#contact">Get in touch with us.</a></p><a class="whyPhone" href="#contact" aria-label="Start a consultation">↗</a></div>
          </article>

          <article class="whyCard whyRetention" data-reveal="up" style="--reveal-delay:100ms">
            <Image class="whyCardPhoto" src={whyTeamImage} alt="" widths={[620, 920]} sizes="(max-width: 680px) 100vw, 34vw" format="webp" quality={88} loading="lazy" />
            <div class="whyPeople" aria-hidden="true">
              <Image src={aboutImage} alt="" width={42} height={42} format="webp" quality={70} loading="lazy" />
              <Image src={serviceImage} alt="" width={42} height={42} format="webp" quality={70} loading="lazy" />
              <Image src={heroImage} alt="" width={42} height={42} format="webp" quality={70} loading="lazy" />
              <Image src={aboutImage} alt="" width={42} height={42} format="webp" quality={70} loading="lazy" />
              <b>62+</b>
            </div>
            <div class="whyRating"><span aria-label="Five star rating">★★★★★</span><small>Happy clients worldwide</small></div>
            <div class="whyRetentionStat"><strong data-count="98" data-suffix="%">0</strong><p>Clients stay for our quality<br />and measurable results.</p></div>
          </article>

          <article class="whyCard whySupport" data-reveal="up" style="--reveal-delay:150ms">
            <Image class="whyCardPhoto" src={whySupportImage} alt="" widths={[520, 760]} sizes="(max-width: 680px) 100vw, 28vw" format="webp" quality={88} loading="lazy" />
            <div><strong>24/7</strong><span>Always-on support</span></div>
            <div class="whyChats" aria-label="Responsive client support">
              <p><i></i><span>Hey there!</span></p>
              <p><i></i><span>How can we help?</span></p>
            </div>
          </article>
        </div>

        <article class="whyFeature" data-reveal="clip" style="--reveal-delay:110ms">
          <Image src={whyFeatureImage} alt="Creative professional in dramatic red studio light" widths={[620, 920, 1200]} sizes="(max-width: 820px) 100vw, 34vw" format="webp" quality={92} loading="lazy" />
          <div class="whyFeatureShade"></div>
          <div class="whyFeatureContent">
            <div class="whyFeatureTitle"><span aria-hidden="true"><i></i><i></i><i></i></span><h3>Why Choose Us?</h3></div>
            <p>We deliver connected strategy, creative execution, and measurable results that help your business move faster and smarter.</p>
            <ul>
              <li>Data-driven decision making</li>
              <li>ROI-focused campaigns</li>
              <li>Experienced creative team</li>
              <li>Transparent reporting</li>
              <li>Scalable growth systems</li>
            </ul>
          </div>
          <a href="#contact">Free Consultation <span aria-hidden="true">↗</span></a>
        </article>
      </div>
    </section>

    <section class="projectShowcase" id="projects" aria-labelledby="projects-title">
      <header class="projectHeader">
        <div>
          <div class="eyebrow" data-reveal="line">Case Studies</div>
          <h2 id="projects-title" data-reveal="title">Our projects that showcase real<br /><span>marketing success.</span></h2>
        </div>
        <div class="projectHeaderAction" data-reveal="up">
          <a class="gradientButton magnetic" href="#contact">View All Projects <b>↗</b></a>
        </div>
      </header>

      <div class="projectCarousel" data-project-carousel>
        <button class="projectArrow projectArrow--prev" type="button" aria-label="View previous project" data-project-prev><span>←</span></button>
        <div class="projectRail" tabindex="0" aria-label="PrysmNexus case studies" data-project-rail>
          {projectStudies.map((project, index) => (
            <article class="projectCard" data-reveal="up" style={`--project-accent:${project.accent};--reveal-delay:${index * 65}ms`}>
              <a class="projectMedia" href="#contact" aria-label={`Discuss a project like ${project.title}`}>
                <Image src={project.image} alt="" widths={[540, 760, 1040]} sizes="(max-width: 760px) 86vw, 34vw" format="webp" quality={90} loading="lazy" />
                <span class="projectCategory">{project.category}</span>
                <span class="projectOpen" aria-hidden="true">↗</span>
              </a>
              <div class="projectCopy"><div><h3>{project.title}</h3><p>{project.copy}</p></div></div>
            </article>
          ))}
        </div>
        <button class="projectArrow projectArrow--next" type="button" aria-label="View next project" data-project-next><span>→</span></button>
        <div class="projectDots" aria-label="Choose a project">
          {projectStudies.map((project, index) => <button type="button" aria-label={`View ${project.title}`} data-project-dot={index}></button>)}
        </div>
      </div>
    </section>

    <section class="workProcess" id="process" aria-labelledby="process-title">
      <Image class="workProcessBg" src={processBackdrop} alt="" widths={[1280, 1920, 2560]} sizes="100vw" format="webp" quality={90} loading="lazy" />
      <div class="workProcessVeil" aria-hidden="true"></div>
      <header class="workProcessHeader">
        <div class="eyebrow" data-reveal="line">Work Process</div>
        <h2 id="process-title" data-reveal="title">Our proven process for consistent<br />marketing success.</h2>
      </header>
      <div class="workProcessSteps">
        {workProcessSteps.map((step, index) => (
          <article class="workProcessStep" data-reveal="up" style={`--reveal-delay:${index * 95}ms`}>
            <span class="workProcessIcon" aria-hidden="true"><b>{step.glyph}</b></span>
            <div class="workProcessName"><h3>{step.title}</h3><strong>{step.number}</strong></div>
            <span class="workProcessLine" aria-hidden="true"><i></i></span>
            <p>{step.copy}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="faq faqEditorial" id="faq">
      <div class="faqShell">
        <header class="faqIntro">
          <div class="eyebrow light" data-reveal="line">Frequently Asked Questions</div>
          <h2 data-reveal="title">A few things worth knowing.</h2>
          <p data-reveal="up">Clear answers about scope, content, advertising, visibility, and measurement.</p>
          <a href="mailto:hello@prysmnexus.agency" data-reveal="up">Ask us directly <span aria-hidden="true">↗</span></a>
        </header>
        <div class="faqGrid">{faqs.map(({ question, answer }, index) => <details open={index === 0} data-reveal="up" style={`--reveal-delay:${(index % 3) * 60}ms`}><summary>{question}<span aria-hidden="true"></span></summary><div class="faqAnswer"><p>{answer}</p></div></details>)}</div>
      </div>
    </section>

    <footer class="editorialFooter" id="contact">
      <div class="footerGlow" aria-hidden="true"></div>
      <div class="footerCta">
        <div><div class="eyebrow light" data-reveal="line">Let’s Work Together</div><h2 data-reveal="title">Ready to make every<br />channel work together?</h2></div>
        <a class="footerCtaButton magnetic" href="mailto:hello@prysmnexus.agency" data-reveal="up"><span>Start a<br />conversation</span><b aria-hidden="true">↗</b></a>
      </div>
      <div class="footerRule"></div>
      <div class="footerInfo" data-reveal="up">
        <a class="logo inverse" href="#home" translate="no"><span class="brandLogo"><img src="/prysmnexus-logo.png" alt="" width="1254" height="1254" /></span><span><b>Prysm<span>Nexus</span></b><small>GROWTH MARKETING</small></span></a>
        <p>Brand, content, demand, and discovery under one accountable team.</p>
        <nav class="footerNav" aria-label="Footer navigation"><a href="#services">Services</a><a href="#method">Method</a><a href="#process">Process</a><a href="#faq">FAQ</a></nav>
        <a class="footerEmail" href="mailto:hello@prysmnexus.agency">hello@prysmnexus.agency</a>
      </div>
      <div class="footerMeta"><small>© 2026 PrysmNexus</small><small>Strategy · Creative · Performance · Search</small><a href="#home">Back to top ↑</a></div>
    </footer>
  </main>

  <script>
    const root = document.documentElement;
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    root.classList.add("motion-ready");

    const menuButton = document.querySelector<HTMLButtonElement>(".menuButton");
    const nav = document.querySelector<HTMLElement>("#primary-nav");
    menuButton?.addEventListener("click", () => {
      const expanded = menuButton.getAttribute("aria-expanded") === "true";
      menuButton.setAttribute("aria-expanded", String(!expanded));
      nav?.classList.toggle("open", !expanded);
    });
    nav?.querySelectorAll("a").forEach((link) => link.addEventListener("click", () => {
      menuButton?.setAttribute("aria-expanded", "false");
      nav.classList.remove("open");
    }));
    document.addEventListener("keydown", (event) => {
      if (event.key !== "Escape" || !nav?.classList.contains("open")) return;
      nav.classList.remove("open");
      menuButton?.setAttribute("aria-expanded", "false");
      menuButton?.focus();
    });

    const smoothSpring = (t: number, b: number, c: number, d: number) => {
      const p = .9;
      const a = 2;
      return c * (1 - Math.exp(-p * t / d)) * Math.sin(a * p * t / d) + b;
    };

    // Advanced reveal system with multiple animation types
    class RevealSystem {
      constructor() {
        this.init();
      }

      init() {
        const revealItems = document.querySelectorAll<HTMLElement>("[data-reveal]");
        if (!revealItems.length) return;

        if (reduceMotion.matches || !("IntersectionObserver" in window)) {
          revealItems.forEach((item) => item.classList.add("is-visible"));
          return;
        }

        // Stagger calculator for rhythmic reveals
        const calculateStagger = (item: HTMLElement, index: number): number => {
          const baseDelay = 80;
          const revealType = item.dataset.reveal;
          const typeVariation = {
            'up': .8, 'title': 1.2, 'clip': 1, 'line': .6, 'row': 1.1
          };
          const rhythm = typeVariation[revealType as keyof typeof typeVariation] || 1;
          
          // Calculate distance-based staggering for organic rhythm
          const distance = item.getBoundingClientRect().top;
          const viewportHeight = window.innerHeight;
          const proximityFactor = Math.max(0, 1 - distance / (viewportHeight + 200));
          
          return baseDelay + (index * 90 * rhythm) + (proximityFactor * 150);
        };

        // Group reveals by type for optimized observation
        const groupedElements = new Map<string, HTMLElement[]>();
        revealItems.forEach((item) => {
          const type = item.dataset.reveal || 'default';
          if (!groupedElements.has(type)) {
            groupedElements.set(type, []);
          }
          groupedElements.get(type)?.push(item);
        });

        groupedElements.forEach((elements, type) => {
          // Different observers for different types with custom thresholds
          const threshold = type === 'title' ? 0.08 : type === 'clip' ? 0.12 : 0.14;
          const observer = new IntersectionObserver((entries, obs) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const item = entry.target as HTMLElement;
              const staggerDelay = calculateStagger(item, Array.from(groupedElements.get(type) || []).indexOf(item));
              item.style.setProperty('--reveal-delay', `${staggerDelay}ms`);
              item.classList.add("reveal-active", "is-visible");

              item.querySelectorAll<HTMLElement>("[data-count]").forEach((counter) => this.animateCounter(counter));
              if (item.matches("[data-count]")) this.animateCounter(item);

              item.querySelectorAll<HTMLElement>(".reveal-child").forEach((child, childIndex) => {
                child.style.setProperty("--child-delay", `${staggerDelay + childIndex * 60}ms`);
                child.classList.add("reveal-active");
              });
              obs.unobserve(item);
            });
          }, { threshold, rootMargin: "0px 0px -5%" });
          
          elements.forEach((element) => observer.observe(element));
        });
      }

      animateCounter(counter: HTMLElement) {
        if (counter.dataset.counted === "true") return;
        counter.dataset.counted = "true";
        const target = Number(counter.dataset.count ?? "0");
        const started = performance.now();
        const duration = 950;
        const startValue = Number(counter.textContent?.match(/\d+/)?.[0] || "0");
        
        const tick = (now: number) => {
          const progress = Math.min((now - started) / duration, 1);
          const eased = smoothSpring(progress, startValue, target - startValue, 1);
          counter.textContent = `${new Intl.NumberFormat(document.documentElement.lang || "en").format(Math.round(eased))}${counter.dataset.suffix ?? ""}`;
          if (progress < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      }
    }

    // Initialize the advanced reveal system
    new RevealSystem();

    // Advanced scroll effects with velocity-based animations
    const progressBar = document.querySelector<HTMLElement>(".scrollProgress span");
    const header = document.querySelector<HTMLElement>("[data-site-header]");
    const glassLayer = document.querySelector<HTMLElement>(".glassLayer");
    const navLinks = document.querySelectorAll<HTMLElement>("#primary-nav a");
    let scrollFrame = 0;
    
    // Velocity calculator for smooth scroll transitions
    let lastScrollY = scrollY;
    let scrollVelocity = 0;
    
    const updateScrollEffects = () => {
      scrollFrame = 0;
      const maxScroll = document.documentElement.scrollHeight - innerHeight;
      const progress = maxScroll > 0 ? scrollY / maxScroll : 0;
      
      // Calculate scroll velocity for dynamic effects
      scrollVelocity = Math.abs(scrollY - lastScrollY) / (performance.now() - (performance.now() - 16));
      lastScrollY = scrollY;
      
      progressBar?.style.setProperty("--scroll-progress", String(progress));
      header?.classList.toggle("is-scrolled", scrollY > 28);
      root.style.setProperty("--hero-scroll", `${Math.min(scrollY * 0.12, 90)}px`);
      
      // Dynamic header scaling based on scroll velocity
      const velocityScale = Math.min(scrollVelocity * 2, 1.5);
      header?.style.setProperty("--header-scale", String(1 + (scrollY > 50 ? velocityScale * 0.03 : 0)));
      
      // Glass layer opacity based on scroll position
      if (glassLayer) {
        const glassOpacity = Math.min(scrollY / 200, 0.8);
        glassLayer.style.setProperty('--glass-opacity', String(glassOpacity));
      }
      
      // Nav link underline position based on scroll
      const navPositions = Array.from(navLinks).map((link) => {
        const targetSection = link.getAttribute('href');
        if (targetSection && targetSection !== '#home') {
          const targetElement = document.querySelector(targetSection);
          if (targetElement) {
            const rect = targetElement.getBoundingClientRect();
            return Math.max(0, Math.min(100, ((innerHeight - rect.top) / (innerHeight + rect.height)) * 100));
          }
        }
        return 0;
      });
      navLinks.forEach((link, index) => link.style.setProperty('--nav-indicator', `${navPositions[index]}%`));
    };
    
    addEventListener("scroll", () => {
      if (!scrollFrame) scrollFrame = requestAnimationFrame(updateScrollEffects);
    }, { passive: true });
    updateScrollEffects();

    const missionContent = [
      ["Our mission is to empower businesses with clear strategies, data-driven insights, and practical solutions that drive sustainable growth, improve performance, and create lasting value in an ever-changing competitive market."],
      ["Our vision is to make connected, accountable digital growth accessible to ambitious brands—bringing strategy, creativity, performance, and discovery into one clear system."],
      ["Our goal is to turn marketing activity into measurable business momentum through focused execution, useful reporting, and continuous improvement across every channel."],
    ];
    const missionTabs = document.querySelectorAll<HTMLButtonElement>("[data-mission-tab]");
    const missionCopy = document.querySelector<HTMLElement>("[data-mission-copy]");
    const activateMissionTab = (tab: HTMLButtonElement) => {
      const index = Number(tab.dataset.missionTab ?? 0);
      missionTabs.forEach((item) => {
        const active = item === tab;
        item.classList.toggle("active", active);
        item.setAttribute("aria-selected", String(active));
        item.tabIndex = active ? 0 : -1;
      });
      if (!missionCopy) return;
      missionCopy.setAttribute("aria-labelledby", tab.id);
      const swap = () => {
        missionCopy.innerHTML = missionContent[index].map((paragraph) => `<p>${paragraph}</p>`).join("");
      };
      if (reduceMotion.matches) return swap();
      missionCopy.animate([{ opacity: 1, transform: "translateY(0)" }, { opacity: 0, transform: "translateY(-8px)" }], { duration: 140, fill: "forwards" }).finished.then(() => {
        swap();
        missionCopy.animate([{ opacity: 0, transform: "translateY(10px)" }, { opacity: 1, transform: "translateY(0)" }], { duration: 360, easing: "cubic-bezier(.16,1,.3,1)", fill: "forwards" });
      }).catch(swap);
    };

    missionTabs.forEach((tab, tabIndex) => {
      tab.addEventListener("click", () => activateMissionTab(tab));
      tab.addEventListener("keydown", (event) => {
        if (!["ArrowLeft", "ArrowRight", "Home", "End"].includes(event.key)) return;
        event.preventDefault();
        const lastIndex = missionTabs.length - 1;
        const nextIndex = event.key === "Home" ? 0 : event.key === "End" ? lastIndex : event.key === "ArrowRight" ? (tabIndex + 1) % missionTabs.length : (tabIndex - 1 + missionTabs.length) % missionTabs.length;
        const nextTab = missionTabs[nextIndex];
        nextTab?.focus();
        if (nextTab) activateMissionTab(nextTab);
      });
    });

    document.querySelectorAll<HTMLDetailsElement>(".faq details").forEach((details) => {
      const summary = details.querySelector("summary");
      const answer = details.querySelector<HTMLElement>(".faqAnswer");
      summary?.addEventListener("keydown", (event) => {
        if (event.key !== "Enter" && event.key !== " ") return;
        event.preventDefault();
        summary.click();
      });
      summary?.addEventListener("click", (event) => {
        if (reduceMotion.matches || !answer) return;
        event.preventDefault();
        if (details.open) {
          const animation = answer.animate([{ height: `${answer.offsetHeight}px`, opacity: 1 }, { height: "0px", opacity: 0 }], { duration: 280, easing: "cubic-bezier(.4,0,.2,1)" });
          animation.onfinish = () => { details.open = false; answer.style.removeProperty("height"); };
        } else {
          details.open = true;
          const height = answer.offsetHeight;
          answer.animate([{ height: "0px", opacity: 0 }, { height: `${height}px`, opacity: 1 }], { duration: 380, easing: "cubic-bezier(.16,1,.3,1)" }).onfinish = () => answer.style.removeProperty("height");
        }
      });
    });

    const projectRail = document.querySelector<HTMLElement>("[data-project-rail]");
    const projectPrevious = document.querySelector<HTMLButtonElement>("[data-project-prev]");
    const projectNext = document.querySelector<HTMLButtonElement>("[data-project-next]");
    const projectDots = document.querySelectorAll<HTMLButtonElement>("[data-project-dot]");
    const projectCarousel = document.querySelector<HTMLElement>("[data-project-carousel]");
    if (projectRail && projectPrevious && projectNext && projectCarousel && projectDots.length) {
      const projectStep = () => {
        const card = projectRail.querySelector<HTMLElement>(".projectCard");
        const gap = Number.parseFloat(getComputedStyle(projectRail).columnGap || "0");
        return (card?.offsetWidth ?? projectRail.clientWidth * .85) + gap;
      };
      const updateProjectCarousel = () => {
        const maximum = Math.max(1, projectRail.scrollWidth - projectRail.clientWidth);
        const activeIndex = Math.min(projectDots.length - 1, Math.max(0, Math.round(projectRail.scrollLeft / projectStep())));
        projectDots.forEach((dot, index) => {
          const active = index === activeIndex;
          dot.classList.toggle("active", active);
          dot.setAttribute("aria-current", active ? "true" : "false");
        });
        projectPrevious.disabled = projectRail.scrollLeft <= 4;
        projectNext.disabled = projectRail.scrollLeft >= maximum - 4;
      };
      projectPrevious.addEventListener("click", () => projectRail.scrollBy({ left: -projectStep(), behavior: reduceMotion.matches ? "auto" : "smooth" }));
      projectNext.addEventListener("click", () => projectRail.scrollBy({ left: projectStep(), behavior: reduceMotion.matches ? "auto" : "smooth" }));
      projectDots.forEach((dot, index) => dot.addEventListener("click", () => projectRail.scrollTo({ left: index * projectStep(), behavior: reduceMotion.matches ? "auto" : "smooth" })));
      projectRail.addEventListener("keydown", (event) => {
        if (event.key !== "ArrowLeft" && event.key !== "ArrowRight") return;
        event.preventDefault();
        projectRail.scrollBy({ left: event.key === "ArrowRight" ? projectStep() : -projectStep(), behavior: reduceMotion.matches ? "auto" : "smooth" });
      });
      let projectScrollFrame = 0;
      projectRail.addEventListener("scroll", () => {
        cancelAnimationFrame(projectScrollFrame);
        projectScrollFrame = requestAnimationFrame(updateProjectCarousel);
      }, { passive: true });
      let dragStart = 0;
      let dragScrollStart = 0;
      let dragging = false;
      let suppressProjectClick = false;
      projectRail.addEventListener("pointerdown", (event) => {
        if (event.pointerType !== "mouse") return;
        dragging = true;
        suppressProjectClick = false;
        dragStart = event.clientX;
        dragScrollStart = projectRail.scrollLeft;
        projectRail.classList.add("is-dragging");
        projectRail.setPointerCapture(event.pointerId);
      });
      projectRail.addEventListener("pointermove", (event) => {
        if (!dragging) return;
        const distance = event.clientX - dragStart;
        if (Math.abs(distance) > 5) suppressProjectClick = true;
        projectRail.scrollLeft = dragScrollStart - distance;
      });
      const stopProjectDrag = (event: PointerEvent) => {
        if (!dragging) return;
        dragging = false;
        projectRail.classList.remove("is-dragging");
        if (projectRail.hasPointerCapture(event.pointerId)) projectRail.releasePointerCapture(event.pointerId);
      };
      projectRail.addEventListener("pointerup", stopProjectDrag);
      projectRail.addEventListener("pointercancel", stopProjectDrag);
      projectRail.addEventListener("click", (event) => {
        if (!suppressProjectClick) return;
        event.preventDefault();
        suppressProjectClick = false;
      }, true);
      let projectAutoTimer = 0;
      const stopProjectAuto = () => window.clearInterval(projectAutoTimer);
      const startProjectAuto = () => {
        stopProjectAuto();
        if (reduceMotion.matches || document.hidden) return;
        projectAutoTimer = window.setInterval(() => {
          const maximum = projectRail.scrollWidth - projectRail.clientWidth;
          const atEnd = projectRail.scrollLeft >= maximum - projectStep() * .3;
          projectRail.scrollTo({ left: atEnd ? 0 : projectRail.scrollLeft + projectStep(), behavior: "smooth" });
        }, 3600);
      };
      projectCarousel.addEventListener("pointerenter", stopProjectAuto);
      projectCarousel.addEventListener("pointerleave", startProjectAuto);
      projectCarousel.addEventListener("focusin", stopProjectAuto);
      projectCarousel.addEventListener("focusout", startProjectAuto);
      document.addEventListener("visibilitychange", () => document.hidden ? stopProjectAuto() : startProjectAuto());
      new ResizeObserver(updateProjectCarousel).observe(projectRail);
      updateProjectCarousel();
      startProjectAuto();
    }

    const finePointer = window.matchMedia("(pointer: fine)");
    const halo = document.querySelector<HTMLElement>(".cursorHalo");
    if (finePointer.matches && !reduceMotion.matches) {
      addEventListener("pointermove", (event) => {
        halo?.style.setProperty("--pointer-x", `${event.clientX}px`);
        halo?.style.setProperty("--pointer-y", `${event.clientY}px`);
        halo?.classList.add("is-active");
      }, { passive: true });
      document.querySelectorAll<HTMLElement>(".magnetic").forEach((element) => {
        element.addEventListener("pointermove", (event) => {
          const rect = element.getBoundingClientRect();
          element.style.setProperty("--magnet-x", `${(event.clientX - rect.left - rect.width / 2) * 0.12}px`);
          element.style.setProperty("--magnet-y", `${(event.clientY - rect.top - rect.height / 2) * 0.12}px`);
        });
        element.addEventListener("pointerleave", () => {
          element.style.setProperty("--magnet-x", "0px");
          element.style.setProperty("--magnet-y", "0px");
        });
      });
    const hero = document.querySelector<HTMLElement>(".hero");
    const heroPortrait = document.querySelector<HTMLElement>(".heroPortrait");
    const heroGlow = document.querySelector<HTMLElement>(".heroGlow");
    const heroCopy = document.querySelector<HTMLElement>(".heroCopy");
    
    if (hero && !reduceMotion.matches) {
      hero.addEventListener("pointermove", (event) => {
        const x = event.clientX / innerWidth - .5;
        const y = event.clientY / innerHeight - .5;
        const intensity = Math.sqrt(x * x + y * y);
        
        hero.style.setProperty("--pointer-shift-x", `${x * 18 * intensity}px`);
        hero.style.setProperty("--pointer-shift-y", `${y * 12 * intensity}px`);
        
        if (heroPortrait) {
          heroPortrait.style.setProperty("--portrait-tilt", `${-y * 8}deg`);
          heroPortrait.style.setProperty("--portrait-scale", `${1 + intensity * .02}`);
        }
        
        if (heroGlow) {
          heroGlow.style.setProperty("--glow-intensity", `${intensity * .6}`);
          heroGlow.style.setProperty("--glow-x", `${x * 50}%`);
          heroGlow.style.setProperty("--glow-y", `${y * 50}%`);
        }
      }, { passive: true });
      
      if (heroCopy) {
        heroCopy.addEventListener("pointermove", (event) => {
          const rect = heroCopy.getBoundingClientRect();
          const x = (event.clientX - rect.left) / rect.width - .5;
          const y = (event.clientY - rect.top) / rect.height - .5;
          heroCopy.style.setProperty("--copy-shift-x", `${x * 5}px`);
          heroCopy.style.setProperty("--copy-shift-y", `${y * 5}px`);
        }, { passive: true });
      }
    }
    }

    const canvas = document.querySelector<HTMLCanvasElement>(".prismCanvas");
    const hero = document.querySelector<HTMLElement>(".hero");
    if (canvas && hero && !reduceMotion.matches) {
      const context = canvas.getContext("2d");
      const points = Array.from({ length: 48 }, (_, index) => ({
        x: ((index * 47) % 101) / 100,
        y: ((index * 73) % 97) / 100,
        speed: .000045 + (index % 7) * .000008 + Math.random() * .000005,
        phase: index * .7 + Math.random() * .5,
        baseRadius: index % 3 === 0 ? 2.2 : 1.2,
        radiusVariation: index % 2 === 0 ? .8 : 1.5,
        colorIntensity: [1, 1, .8, .9][index % 4],
        velocityX: (Math.random() - .5) * .0002,
        velocityY: (Math.random() - .5) * .0002,
      }));
      let canvasWidth = 0;
      let canvasHeight = 0;
      let canvasVisible = true;
      let canvasFrame = 0;
      const resizeCanvas = () => {
        const ratio = Math.min(devicePixelRatio, 1.5);
        canvasWidth = hero.clientWidth;
        canvasHeight = hero.clientHeight;
        canvas.width = Math.round(canvasWidth * ratio);
        canvas.height = Math.round(canvasHeight * ratio);
        canvas.style.width = `${canvasWidth}px`;
        canvas.style.height = `${canvasHeight}px`;
        context?.setTransform(ratio, 0, 0, ratio, 0, 0);
      };
      const drawPrisms = (time: number) => {
        if (!context || !canvasVisible) { canvasFrame = requestAnimationFrame(drawPrisms); return; }
        context.clearRect(0, 0, canvasWidth, canvasHeight);
        
        const positioned = points.map((point) => {
          const x = point.x * canvasWidth + Math.sin(time * point.speed + point.phase) * 22;
          const y = point.y * canvasHeight + Math.cos(time * point.speed * 1.3 + point.phase) * 16;
          
          point.x += point.velocityX * time;
          point.y += point.velocityY * time;
          
          point.phase += .008;
          
          point.velocityX = Math.max(Math.min(point.velocityX + (Math.random() - .5) * .00002, .0005), -.0005);
          point.velocityY = Math.max(Math.min(point.velocityY + (Math.random() - .5) * .00002, .0005), -.0005);
          
          point.x = Math.max(0.02, Math.min(0.98, point.x));
          point.y = Math.max(0.02, Math.min(0.98, point.y));
          
          return { ...point, x, y };
        });
        
        for (let index = 0; index < positioned.length; index += 1) {
          for (let next = index + 1; next < positioned.length; next += 1) {
            const dx = positioned[index].x - positioned[next].x;
            const dy = positioned[index].y - positioned[next].y;
            const distance = Math.hypot(dx, dy) * Math.min(canvasWidth, canvasHeight);
            if (distance > 185) continue;
            context.beginPath();
            context.moveTo(positioned[index].x * canvasWidth, positioned[index].y * canvasHeight);
            context.lineTo(positioned[next].x * canvasWidth, positioned[next].y * canvasHeight);
            context.strokeStyle = `rgba(255,35,47,${(1 - distance / 185) * .13 * positioned[index].colorIntensity})`;
            context.lineWidth = .7;
            context.stroke();
          }
        }
        positioned.forEach((point, index) => {
          context.beginPath();
          const radius = point.baseRadius * (1 + Math.sin(time * .002 + index * .1) * point.radiusVariation * .15);
          context.arc(point.x * canvasWidth, point.y * canvasHeight, radius, 0, Math.PI * 2);
          context.fillStyle = index % 4 === 0 ? `rgba(255,255,255,${.48 * point.colorIntensity})` : `rgba(255,28,39,${.38 * point.colorIntensity})`;
          context.fill();
          
          if (index % 6 === 0) {
            context.beginPath();
            context.arc(point.x * canvasWidth, point.y * canvasHeight, 6, 0, Math.PI * 2);
            context.fillStyle = `rgba(255,35,47,${.4 * point.colorIntensity})`;
            context.fill();
          }
        });
        canvasFrame = requestAnimationFrame(drawPrisms);
      };
      new ResizeObserver(resizeCanvas).observe(hero);
      new IntersectionObserver(([entry]) => { canvasVisible = entry.isIntersecting && !document.hidden; }).observe(hero);
      document.addEventListener("visibilitychange", () => { canvasVisible = !document.hidden && hero.getBoundingClientRect().bottom > 0; });
      resizeCanvas();
      canvasFrame = requestAnimationFrame(drawPrisms);
      addEventListener("pagehide", () => cancelAnimationFrame(canvasFrame), { once: true });
    }
  </script>
</BaseLayout>
