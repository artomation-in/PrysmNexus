---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import aboutImage from "../assets/about-prysmnexus-v2.png";
import serviceImage from "../assets/service.webp";
import heroImage from "../assets/hero.png";
import processBackdrop from "../assets/work-process-prism.png";
import whyAnalyticsImage from "../assets/why-analytics.jpg";
import whyFeatureImage from "../assets/why-feature-prysmnexus-v2.png";
import whyTeamImage from "../assets/why-team-v2.png";
import whySupportImage from "../assets/why-planning-v2.png";
import projectBrandImage from "../assets/case-study-1.jpg";
import projectSocialImage from "../assets/case-study-2.jpg";
import projectContentImage from "../assets/case-study-3.jpg";
import capabilityBrandingImage from "../assets/capability-branding-hq.png";
import capabilityContentImage from "../assets/capability-content-hq.png";
import capabilityTeamImage from "../assets/capability-team-hq.png";
import capabilitySearchImage from "../assets/capability-search-hq.png";
import prysmNexusLogo from "../assets/prysmnexus-logo-mark-hq-transparent.png";
import clientCafeBelloso from "../assets/client-cafe-belloso.png";
import clientStatDelight from "../assets/client-stat-delight.png";
import clientJathara from "../assets/client-jathara.png";
import clientSmileyFashionAcademy from "../assets/client-smiley-fashion-academy.png";
import { brand as seoBrand, services as seoServices } from "../data/seo";

const services = [
  { number: "01", slug: "brand-strategy", title: "Strategic Branding", description: "Sharp positioning, a clear voice, and a consistent visual direction designed to make your business recognizable and memorable.", bullets: ["Brand positioning", "Visual identity", "Messaging framework", "Campaign toolkit"] },
  { number: "02", slug: "content-production", title: "Photography & Video", description: "Original photography, video, reels, and campaign creatives produced around your business—not pulled from recycled templates.", bullets: ["Photography and styling", "Video production", "Reels and short-form", "Creative copy"] },
  { number: "03", slug: "social-media-management", title: "Social Media Management", description: "Planned content, active page management, and audience engagement that keep your brand visible, relevant, and consistent.", bullets: ["Monthly content calendar", "Publishing and page handling", "Community engagement", "WhatsApp marketing"] },
  { number: "04", slug: "performance-marketing", title: "Performance Marketing", description: "Google and Meta campaigns built to generate qualified enquiries, with clear optimization, reporting, and commercial focus.", bullets: ["Google and Meta ads", "Lead generation", "Campaign optimization", "Monthly reporting"] },
  { number: "05", slug: "seo-local-search-reputation", title: "Search & Reputation", description: "SEO, Google Business Profile, local discovery, and review management that help customers find and trust your business.", bullets: ["SEO and local search", "Google Business Profile", "Review management", "Online visibility"] },
  { number: "06", slug: "ai-automation-systems", title: "AI Automation Systems", description: "Connected CRM, messaging, AI-agent, and operational workflows that reduce repetitive work while keeping your team in control.", bullets: ["CRM automation", "WhatsApp workflows", "Custom AI agents", "n8n orchestration"] },
  { number: "07", slug: "brand-pr-authority", title: "Brand & PR Authority", description: "Positioning, media outreach, founder visibility, and thought leadership designed to build credible market authority.", bullets: ["Digital PR", "Founder authority", "Media outreach", "LinkedIn strategy"] },
  { number: "08", slug: "custom-software-saas", title: "Custom Software & SaaS", description: "Purpose-built software, SaaS products, internal applications, and modernization shaped around real business workflows.", bullets: ["Custom software", "SaaS platforms", "Enterprise apps", "MVP development"] },
];

const projectStudies = [
  { image: projectBrandImage, category: "Brand / Strategy", title: "Sharper Brand Positioning", copy: "A clear visual and messaging system designed for consistent recognition across every customer touchpoint.", result: "Clearer brand recall", accent: "#e45d5e" },
  { image: projectSocialImage, category: "Social / Content", title: "Hospitality Content Engine", copy: "Photography, reels, stories, and active publishing shaped around how local audiences discover and choose.", result: "Consistent visibility", accent: "#ef8d48" },
  { image: projectContentImage, category: "Google / Meta", title: "Qualified Enquiry Campaigns", copy: "Focused creative, audience testing, and ongoing optimization built around meaningful business enquiries.", result: "Commercial focus", accent: "#d9353a" },
  { image: whyAnalyticsImage, category: "Creative / Production", title: "Original Campaign Content", copy: "Brand-led photography, video, and short-form creative made to look distinctive across digital channels.", result: "Original production", accent: "#e77248" },
  { image: whyTeamImage, category: "Search / Reputation", title: "Local Discovery System", copy: "SEO, Google Business Profile, useful content, and reputation signals aligned to improve customer discovery.", result: "Stronger local presence", accent: "#cc3f46" },
];

const featuredClients = [
  { key: "jathara", image: clientJathara, name: "Jathara", category: "Bar & Kitchen" },
  { key: "belloso", image: clientCafeBelloso, name: "Cafe Belloso", category: "Hospitality" },
  { key: "stat-delight", image: clientStatDelight, name: "Stat Delight", category: "Brand & Content" },
  { key: "smiley-fashion", image: clientSmileyFashionAcademy, name: "Smiley Fashion Academy", category: "Fashion Education" },
];

const workProcessSteps = [
  { number: "01", glyph: "◎", title: "Discover", copy: "We assess your goals, audience, current channels, and market position to understand what the business needs most." },
  { number: "02", glyph: "≋", title: "Analyze", copy: "We examine brand, content, campaign, and search performance to uncover gaps and practical opportunities." },
  { number: "03", glyph: "◇", title: "Strategize", copy: "We shape a connected, actionable growth plan aligned with your priorities, resources, and commercial goals." },
  { number: "04", glyph: "↗", title: "Execute & Optimize", copy: "We launch, measure, learn, and continuously improve the work to build sustainable momentum." },
];

const faqs = [
  { question: "What does PrysmNexus handle?", answer: "PrysmNexus brings strategic branding, content, social media, paid campaigns, SEO, AI automation, brand authority, and custom software under one accountable team." },
  { question: "Do you produce original content?", answer: "Yes. Photography, video, reels, campaign creatives, stories, and copy are developed around your brand, audience, and commercial goals—not recycled from generic templates." },
  { question: "Can you manage Google and Meta advertising?", answer: "Yes. Campaign work can cover account setup, audience and creative planning, lead generation, conversion paths, optimization, and reporting." },
  { question: "How do you improve local visibility?", answer: "We combine local SEO, Google Business Profile improvements, useful website content, and reputation management to strengthen discovery and trust." },
  { question: "Do you offer fixed packages?", answer: "Every scope is shaped around the channels, production volume, campaign needs, and support your business actually requires. We recommend the right mix after a focused discovery review." },
  { question: "How is performance measured?", answer: "We agree on relevant baselines and report against practical signals such as reach, engagement, qualified leads, search visibility, profile actions, and conversions." },
];

const siteUrl = (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, "");
const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${siteUrl}/#organization`,
    name: "PrysmNexus",
    url: `${siteUrl}/`,
    logo: `${siteUrl}/prysmnexus-logo.png`,
    description: "PrysmNexus is an India-focused growth, automation, and software partner combining marketing, AI workflows, brand authority, and custom digital products.",
    email: seoBrand.email,
    areaServed: { "@type": "Country", name: "India" },
    hasOfferCatalog: { "@type": "OfferCatalog", name: "Growth marketing services", itemListElement: seoServices.map((service) => ({ "@type": "Offer", itemOffered: { "@type": "Service", name: service.name, url: `${siteUrl}/services/${service.slug}/` } })) },
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${siteUrl}/#website`,
    url: `${siteUrl}/`,
    name: "PrysmNexus",
    publisher: { "@id": `${siteUrl}/#organization` },
    inLanguage: "en",
  },
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "@id": `${siteUrl}/#service`,
    name: "PrysmNexus Growth, Automation, and Software Services",
    url: `${siteUrl}/`,
    provider: { "@id": `${siteUrl}/#organization` },
    serviceType: ["Brand Strategy", "Content Production", "Social Media Management", "Performance Marketing", "Search Engine Optimization", "AI Automation Systems", "Digital PR", "Founder Authority Building", "Custom Software Development", "SaaS Development"],
    areaServed: { "@type": "Country", name: "India" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map(({ question, answer }) => ({
      "@type": "Question",
      name: question,
      acceptedAnswer: { "@type": "Answer", text: answer },
    })),
  },
];
---

<BaseLayout
  title="PrysmNexus — Growth, AI Automation & Software in India"
  description="PrysmNexus combines growth marketing, AI automation, brand authority, and custom software services for ambitious businesses across India."
  schemas={schemas}
>
  <div class="scrollProgress" aria-hidden="true"><span></span></div>
  <div class="cursorHalo" aria-hidden="true"></div>
  <main id="main-content">
    <section class="hero" id="home" aria-labelledby="hero-heading">
      <canvas class="prismCanvas" aria-hidden="true"></canvas>
      <header class="siteHeader" data-site-header>
        <a class="logo" href="#home" aria-label="PrysmNexus home" translate="no">
          <span class="brandLogo"><Image src={prysmNexusLogo} alt="" widths={[96, 144, 192, 256]} sizes="(max-width: 760px) 48px, 62px" format="webp" quality={100} loading="eager" /></span>
          <span class="brandWordmark"><svg xmlns="http://www.w3.org/2000/svg" viewBox="518 576 744 278" fill="none">
