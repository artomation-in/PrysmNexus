---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import aboutImage from "../assets/about-prysmnexus-v2.png";
import serviceImage from "../assets/service.webp";
import heroImage from "../assets/hero.png";
import processBackdrop from "../assets/work-process-prism.png";
import whyAnalyticsImage from "../assets/why-analytics.jpg";
import whyFeatureImage from "../assets/why-feature-prysmnexus-v2.png";
import whyTeamImage from "../assets/why-team-v2.png";
import whySupportImage from "../assets/why-planning-v2.png";
import projectBrandImage from "../assets/case-campaign-plan.jpg";
import projectSocialImage from "../assets/case-content-plan.jpg";
import projectContentImage from "../assets/case-strong-brand.jpg";
import capabilityBrandingImage from "../assets/capability-branding-hq.png";
import capabilityContentImage from "../assets/capability-content-hq.png";
import capabilityTeamImage from "../assets/capability-team-hq.png";
import capabilitySearchImage from "../assets/capability-search-hq.png";
import prysmNexusLogo from "../assets/prysmnexus-logo-mark-hq-transparent.png";
import clientCafeBelloso from "../assets/client-cafe-belloso.png";
import clientStatDelight from "../assets/client-stat-delight.png";
import clientJathara from "../assets/client-jathara.png";
import { brand as seoBrand, services as seoServices } from "../data/seo";

const services = [
  { number: "01", slug: "brand-strategy", title: "Strategic Branding", description: "Sharp positioning, a clear voice, and a consistent visual direction designed to make your business recognizable and memorable.", bullets: ["Brand positioning", "Visual identity", "Messaging framework", "Campaign toolkit"] },
  { number: "02", slug: "content-production", title: "Photography & Video", description: "Original photography, video, reels, and campaign creatives produced around your business—not pulled from recycled templates.", bullets: ["Photography and styling", "Video production", "Reels and short-form", "Creative copy"] },
  { number: "03", slug: "social-media-management", title: "Social Media Management", description: "Planned content, active page management, and audience engagement that keep your brand visible, relevant, and consistent.", bullets: ["Monthly content calendar", "Publishing and page handling", "Community engagement", "WhatsApp marketing"] },
  { number: "04", slug: "performance-marketing", title: "Performance Marketing", description: "Google and Meta campaigns built to generate qualified enquiries, with clear optimization, reporting, and commercial focus.", bullets: ["Google and Meta ads", "Lead generation", "Campaign optimization", "Monthly reporting"] },
  { number: "05", slug: "seo-local-search-reputation", title: "Search & Reputation", description: "SEO, Google Business Profile, local discovery, and review management that help customers find and trust your business.", bullets: ["SEO and local search", "Google Business Profile", "Review management", "Online visibility"] },
  { number: "06", slug: "ai-automation-systems", title: "AI Automation Systems", description: "Connected CRM, messaging, AI-agent, and operational workflows that reduce repetitive work while keeping your team in control.", bullets: ["CRM automation", "WhatsApp workflows", "Custom AI agents", "n8n orchestration"] },
  { number: "07", slug: "brand-pr-authority", title: "Brand & PR Authority", description: "Positioning, media outreach, founder visibility, and thought leadership designed to build credible market authority.", bullets: ["Digital PR", "Founder authority", "Media outreach", "LinkedIn strategy"] },
  { number: "08", slug: "custom-software-saas", title: "Custom Software & SaaS", description: "Purpose-built software, SaaS products, internal applications, and modernization shaped around real business workflows.", bullets: ["Custom software", "SaaS platforms", "Enterprise apps", "MVP development"] },
];

const projectStudies = [
  { image: projectBrandImage, category: "Brand / Strategy", title: "Sharper Brand Positioning", copy: "A clear visual and messaging system designed for consistent recognition across every customer touchpoint.", result: "Clearer brand recall", accent: "#e45d5e" },
  { image: projectSocialImage, category: "Social / Content", title: "Hospitality Content Engine", copy: "Photography, reels, stories, and active publishing shaped around how local audiences discover and choose.", result: "Consistent visibility", accent: "#ef8d48" },
  { image: whyAnalyticsImage, category: "Google / Meta", title: "Qualified Enquiry Campaigns", copy: "Focused creative, audience testing, and ongoing optimization built around meaningful business enquiries.", result: "Commercial focus", accent: "#d9353a" },
  { image: projectContentImage, category: "Creative / Production", title: "Original Campaign Content", copy: "Brand-led photography, video, and short-form creative made to look distinctive across digital channels.", result: "Original production", accent: "#e77248" },
  { image: whyTeamImage, category: "Search / Reputation", title: "Local Discovery System", copy: "SEO, Google Business Profile, useful content, and reputation signals aligned to improve customer discovery.", result: "Stronger local presence", accent: "#cc3f46" },
];

const featuredClients = [
  { key: "jathara", image: clientJathara, name: "Jathara", category: "Bar & Kitchen" },
  { key: "belloso", image: clientCafeBelloso, name: "Cafe Belloso", category: "Hospitality" },
  { key: "stat-delight", image: clientStatDelight, name: "Stat Delight", category: "Brand & Content" },
];

const workProcessSteps = [
  { number: "01", glyph: "◎", title: "Discover", copy: "We assess your goals, audience, current channels, and market position to understand what the business needs most." },
  { number: "02", glyph: "≋", title: "Analyze", copy: "We examine brand, content, campaign, and search performance to uncover gaps and practical opportunities." },
  { number: "03", glyph: "◇", title: "Strategize", copy: "We shape a connected, actionable growth plan aligned with your priorities, resources, and commercial goals." },
  { number: "04", glyph: "↗", title: "Execute & Optimize", copy: "We launch, measure, learn, and continuously improve the work to build sustainable momentum." },
];

const faqs = [
  { question: "What does PrysmNexus handle?", answer: "PrysmNexus brings strategic branding, content, social media, paid campaigns, SEO, AI automation, brand authority, and custom software under one accountable team." },
  { question: "Do you produce original content?", answer: "Yes. Photography, video, reels, campaign creatives, stories, and copy are developed around your brand, audience, and commercial goals—not recycled from generic templates." },
  { question: "Can you manage Google and Meta advertising?", answer: "Yes. Campaign work can cover account setup, audience and creative planning, lead generation, conversion paths, optimization, and reporting." },
  { question: "How do you improve local visibility?", answer: "We combine local SEO, Google Business Profile improvements, useful website content, and reputation management to strengthen discovery and trust." },
  { question: "Do you offer fixed packages?", answer: "Every scope is shaped around the channels, production volume, campaign needs, and support your business actually requires. We recommend the right mix after a focused discovery review." },
  { question: "How is performance measured?", answer: "We agree on relevant baselines and report against practical signals such as reach, engagement, qualified leads, search visibility, profile actions, and conversions." },
];

const siteUrl = (Astro.site ?? Astro.url.origin).toString().replace(/\/$/, "");
const schemas = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${siteUrl}/#organization`,
    name: "PrysmNexus",
    url: `${siteUrl}/`,
    logo: `${siteUrl}/prysmnexus-logo.png`,
    description: "PrysmNexus is an India-focused growth, automation, and software partner combining marketing, AI workflows, brand authority, and custom digital products.",
    email: seoBrand.email,
    areaServed: { "@type": "Country", name: "India" },
    hasOfferCatalog: { "@type": "OfferCatalog", name: "Growth marketing services", itemListElement: seoServices.map((service) => ({ "@type": "Offer", itemOffered: { "@type": "Service", name: service.name, url: `${siteUrl}/services/${service.slug}/` } })) },
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${siteUrl}/#website`,
    url: `${siteUrl}/`,
    name: "PrysmNexus",
    publisher: { "@id": `${siteUrl}/#organization` },
    inLanguage: "en",
  },
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "@id": `${siteUrl}/#service`,
    name: "PrysmNexus Growth, Automation, and Software Services",
    url: `${siteUrl}/`,
    provider: { "@id": `${siteUrl}/#organization` },
    serviceType: ["Brand Strategy", "Content Production", "Social Media Management", "Performance Marketing", "Search Engine Optimization", "AI Automation Systems", "Digital PR", "Founder Authority Building", "Custom Software Development", "SaaS Development"],
    areaServed: { "@type": "Country", name: "India" },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map(({ question, answer }) => ({
      "@type": "Question",
      name: question,
      acceptedAnswer: { "@type": "Answer", text: answer },
    })),
  },
];
---

<BaseLayout
  title="PrysmNexus — Growth, AI Automation & Software in India"
  description="PrysmNexus combines growth marketing, AI automation, brand authority, and custom software services for ambitious businesses across India."
  schemas={schemas}
>
  <div class="scrollProgress" aria-hidden="true"><span></span></div>
  <div class="cursorHalo" aria-hidden="true"></div>
  <main id="main-content">
    <section class="hero" id="home" aria-labelledby="hero-heading">
      <canvas class="prismCanvas" aria-hidden="true"></canvas>
      <header class="siteHeader" data-site-header>
        <a class="logo" href="#home" aria-label="PrysmNexus home" translate="no">
          <span class="brandLogo"><Image src={prysmNexusLogo} alt="" widths={[96, 144, 192, 256]} sizes="(max-width: 760px) 48px, 62px" format="webp" quality={100} loading="eager" /></span>
          <span><b>Prysm<span>Nexus</span></b><small>GROWTH MARKETING</small></span>
        </a>
        <button class="menuButton" type="button" aria-label="Open navigation" aria-expanded="false" aria-controls="primary-nav">
          <span aria-hidden="true"></span><span aria-hidden="true"></span><span aria-hidden="true"></span>
        </button>
        <nav id="primary-nav" aria-label="Primary navigation">
          <a href="#home">Home</a><a href="/services/">Services</a><a href="/about/">About</a><a href="#projects">Our Works</a><a href="#faq">FAQ</a><a href="/contact/">Contact</a><a class="mobileConsult" href="/contact/#consultation-form"><span>Free Consultation</span><b aria-hidden="true">↗</b></a>
        </nav>
        <div class="headerActions"><span class="dash"></span><a class="consult" href="/contact/#consultation-form">Free Consultation</a><span class="gridButton" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i><i></i></span></div>
      </header>
      <div class="mobileNavBackdrop" aria-hidden="true"></div>
      <div class="heroGlow"></div>
      <div class="heroLayout">
        <h1 class="heroTitle" id="hero-heading"><span class="heroWord"><em>Growth</em></span><strong class="heroWord"><em>Marketing</em></strong><small>Built Around Your Business.</small></h1>
        <div class="focused" aria-hidden="true"><span>Focused</span></div>
        <div class="heroCopy" data-reveal="up">
          <p><strong>Sharp branding. Original content. Accountable growth.</strong> PrysmNexus brings strategy, creative production, social media, paid campaigns, and search visibility together for businesses across India.</p>
          <a class="gradientButton" href="#services">Explore Services <b>↗</b></a>
        </div>
      </div>
    </section>

    <section class="capabilityShowcase" aria-label="Core marketing capabilities">
      <div class="capabilityPanel">
        {[
          ["Strategic Branding", "Clear positioning and visual direction that make your business recognizable.", "↗", capabilityBrandingImage, "Brand strategy materials arranged on a creative studio table"],
          ["Original Content", "Photography, video, reels, and creative work produced for your brand.", "✦", capabilityContentImage, "Filmmaker preparing a professional cinema camera in a content studio"],
          ["One Accountable Team", "Strategy, production, publishing, campaigns, and reporting managed together.", "◎", capabilityTeamImage, "Integrated marketing team collaborating around one campaign plan"],
          ["Search & Reputation", "SEO, Google profile, local discovery, and trust signals working as one.", "⌕", capabilitySearchImage, "Search visibility and reputation analytics across laptop and mobile"],
        ].map(([title, text, glyph, image, alt], index) => (
          <article class="capabilityCard" data-reveal="up" style={`--reveal-delay:${index * 100}ms`}>
            <div class="capabilityPhoto"><Image class="capabilityImage" src={image} alt={alt} widths={[480, 720, 960, 1440, 2048]} sizes="(max-width: 760px) calc(100vw - 44px), (max-width: 1100px) 46vw, 24vw" format="webp" quality={92} loading={index === 0 ? "eager" : "lazy"} /></div>
            <span class="capabilityIcon" aria-hidden="true"><b>{glyph}</b></span>
            <h2>{title}</h2>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="about" id="about">
      <div class="aboutShowcase">
        <div class="aboutVisual" data-reveal="clip"><Image src={aboutImage} alt="PrysmNexus strategy team collaborating on a brand campaign" widths={[560, 760, 960, 1200]} sizes="(max-width: 760px) 100vw, (max-width: 1100px) 40vw, 636px" format="webp" quality={92} loading="lazy" /></div>
        <div class="aboutContent">
          <div class="eyebrow" data-reveal="line">About Us</div>
          <h2 data-reveal="title">We help brands grow faster with<br />powerful digital marketing strategies.</h2>
          <div class="aboutMetrics" data-reveal="up">
            <article class="experienceMetric">
              <Image class="metricMark" src={prysmNexusLogo} alt="" widths={[160, 240, 320]} sizes="100px" format="webp" quality={100} loading="lazy" />
              <strong data-count="348" data-suffix="K+">0</strong>
              <span>Content Views<br />Generated</span>
            </article>
            <article class="wide loyaltyMetric">
              <Image class="metricBackdrop" src={serviceImage} alt="" widths={[520, 760]} sizes="(max-width: 760px) 100vw, 34vw" format="webp" quality={72} loading="lazy" />
              <strong data-count="510" data-suffix="K+">0</strong>
              <div class="metricAvatars" aria-hidden="true">
                <Image src={aboutImage} alt="" width={42} height={42} format="webp" quality={70} loading="lazy" />
                <Image src={serviceImage} alt="" width={42} height={42} format="webp" quality={70} loading="lazy" />
                <Image src={aboutImage} alt="" width={42} height={42} format="webp" quality={70} loading="lazy" />
                <Image src={serviceImage} alt="" width={42} height={42} format="webp" quality={70} loading="lazy" />
              </div>
              <span>Audience Reach Across Campaigns</span>
            </article>
          </div>
          <div class="mission aboutMission" data-reveal="up">
            <Image class="missionBackdrop" src={serviceImage} alt="" widths={[640, 900]} sizes="(max-width: 760px) 100vw, 48vw" format="webp" quality={66} loading="lazy" />
            <div class="tabs" role="tablist" aria-label="About PrysmNexus">
              <button class="active" id="about-tab-mission" type="button" role="tab" aria-selected="true" aria-controls="about-panel" tabindex="0" data-mission-tab="0">Our Mission</button>
              <button id="about-tab-vision" type="button" role="tab" aria-selected="false" aria-controls="about-panel" tabindex="-1" data-mission-tab="1">Our Vision</button>
              <button id="about-tab-goal" type="button" role="tab" aria-selected="false" aria-controls="about-panel" tabindex="-1" data-mission-tab="2">Our Goal</button>
            </div>
            <div class="missionCopy" id="about-panel" role="tabpanel" aria-labelledby="about-tab-mission" aria-live="polite" tabindex="0" data-mission-copy><p>Our mission is to give every client hands-on attention, original creative work, and marketing built around what genuinely grows the business.</p></div>
          </div>
          <p class="aboutSummary" data-reveal="up">We combine strategy, original content, and performance marketing into one connected system—from brand awareness and audience engagement to qualified demand.</p>
          <a class="gradientButton magnetic" href="#services" data-reveal="up">Know About Us <b>↗</b></a>
        </div>
      </div>
    </section>

    <section class="reviews" aria-label="Working principles"><div class="reviewTrack">{[0, 1].map((set) => <div class="reviewSet" aria-hidden={set === 1 ? "true" : undefined}><div><span>“Make the brand clear.”</span><b>POSITIONING</b></div><div><span>“Create, do not recycle.”</span><b>ORIGINALITY</b></div><div><span>“Connect every channel.”</span><b>CONSISTENCY</b></div><div><span>“Measure what matters.”</span><b>ACCOUNTABILITY</b></div></div>)}</div></section>

    <section class="services servicesShowcase" id="services">
      <div class="servicesAura" aria-hidden="true"></div>
      <header class="servicesHeader">
        <div>
          <div class="eyebrow light" data-reveal="line">What We Do</div>
          <h2 data-reveal="title">One team.<br /><span>Every growth lever.</span></h2>
        </div>
        <div class="servicesLead" data-reveal="up">
          <p>Brand, demand, automation, authority, and software—connected around one practical growth system.</p>
          <a href="/services/">Explore every service <span aria-hidden="true">↗</span></a>
        </div>
      </header>

      <div class="serviceBento">
        {services.map((service, index) => (
          <article class:list={["serviceCard", index === 0 && "serviceCardFeatured"]} data-reveal="up" style={`--reveal-delay:${index * 70}ms`}>
            <div class="serviceCardTop">
              <span class="serviceNumber">{service.number}</span>
              <a class="serviceArrow" href={`/services/${service.slug}/`} aria-label={`Explore ${service.title}`}>↗</a>
            </div>
            {index === 0 && (
              <div class="serviceBrandMark" aria-hidden="true">
                <span></span><span></span><span></span>
                <Image src={prysmNexusLogo} alt="" widths={[160, 240, 320]} sizes="112px" format="webp" quality={100} loading="lazy" />
              </div>
            )}
            <div class="serviceCardBody">
              <h3><a href={`/services/${service.slug}/`}>{service.title}</a></h3>
              <p>{service.description}</p>
              <ul aria-label={`${service.title} capabilities`}>
                {service.bullets.slice(0, index === 0 ? 4 : 2).map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="whyChoose" id="method" aria-labelledby="why-choose-title">
      <header class="whyChooseHeader">
        <div>
          <div class="eyebrow" data-reveal="line">Why Choose Us</div>
          <h2 id="why-choose-title" data-reveal="title">Original work. Hands-on support.<br />Built around your business.</h2>
        </div>
        <p data-reveal="up">No recycled templates and no disconnected suppliers—just one focused team combining creative craft, technology, and measurable marketing strategy.</p>
      </header>

      <div class="whyChooseLayout">
        <div class="whyChooseBento">
          <article class="whyCard whyCapabilities" data-reveal="up">
            <h3>Capabilities We Bring</h3>
            <div class="whyRibbon" aria-label="PrysmNexus capabilities">
              <div class="whyRibbonRow">
                <span>Brand Strategy</span><span>AI Automation</span><span>Custom Software</span><span>Performance Marketing</span><span>SEO</span><span>Digital PR</span><span>Brand Strategy</span><span>AI Automation</span><span>Custom Software</span><span>Performance Marketing</span><span>SEO</span><span>Digital PR</span>
              </div>
              <div class="whyRibbonRow reverse">
                <span>AI Agents</span><span>CRM Automation</span><span>WhatsApp Bots</span><span>SaaS Platforms</span><span>Founder Authority</span><span>Video</span><span>AI Agents</span><span>CRM Automation</span><span>WhatsApp Bots</span><span>SaaS Platforms</span><span>Founder Authority</span><span>Video</span>
              </div>
              <div class="whyRibbonRow">
                <span>Google Ads</span><span>Meta Ads</span><span>Workflow Design</span><span>System Modernization</span><span>MVP Development</span><span>Identity</span><span>Google Ads</span><span>Meta Ads</span><span>Workflow Design</span><span>System Modernization</span><span>MVP Development</span><span>Identity</span>
              </div>
            </div>
          </article>

          <article class="whyCard whyProjects" data-reveal="up" style="--reveal-delay:70ms">
            <div class="whyProjectVisual">
              <Image src={whyAnalyticsImage} alt="Marketing analytics displayed on a laptop" widths={[520, 760, 1040]} sizes="(max-width: 820px) 100vw, 30vw" format="webp" quality={92} loading="lazy" />
              <div><strong>360°</strong><span>Connected delivery</span></div>
            </div>
            <div class="whyProjectCta"><p>Let’s make great work together.<br /><a href="#contact">Get in touch with us.</a></p><a class="whyPhone" href="#contact" aria-label="Start a consultation">↗</a></div>
          </article>

          <article class="whyCard whyVisualCard whyTeamCard" data-reveal="up" style="--reveal-delay:100ms">
            <Image class="whyCardPhoto" src={whyTeamImage} alt="PrysmNexus marketing team collaborating on campaign strategy" widths={[620, 920]} sizes="(max-width: 680px) 100vw, 34vw" format="webp" quality={90} loading="lazy" />
            <div class="whyVisualBadge"><i aria-hidden="true"></i> One accountable team</div>
            <div class="whyVisualCopy">
              <span>From first idea to final report</span>
              <strong>One team.<br />Clear ownership.</strong>
              <div class="whyVisualTags" aria-label="Connected capabilities"><b>Strategy</b><b>Creative</b><b>Media</b><b>Reporting</b></div>
            </div>
          </article>

          <article class="whyCard whyVisualCard whyPlanningCard" data-reveal="up" style="--reveal-delay:150ms">
            <Image class="whyCardPhoto" src={whySupportImage} alt="Monthly marketing plan and performance reporting workspace" widths={[520, 760]} sizes="(max-width: 680px) 100vw, 28vw" format="webp" quality={90} loading="lazy" />
            <div class="whyVisualBadge light"><i aria-hidden="true"></i> Monthly growth rhythm</div>
            <div class="whyPlanningCopy">
              <strong>Plan. Launch. Learn.</strong>
              <ol aria-label="Monthly marketing workflow">
                <li><b>01</b><span>Priorities</span></li>
                <li><b>02</b><span>Action</span></li>
                <li><b>03</b><span>Results</span></li>
              </ol>
            </div>
          </article>
        </div>

        <article class="whyFeature" data-reveal="clip" style="--reveal-delay:110ms">
          <Image src={whyFeatureImage} alt="Creative growth strategist reviewing a campaign in a PrysmNexus red and graphite studio" widths={[620, 920, 1200]} sizes="(max-width: 820px) 100vw, 34vw" format="webp" quality={92} loading="lazy" />
          <div class="whyFeatureShade"></div>
          <div class="whyFeatureContent">
            <div class="whyFeatureTitle"><span aria-hidden="true"><i></i><i></i><i></i></span><h3>Why Choose Us?</h3></div>
            <p>We combine creative craft, digital execution, and clear reporting so every channel supports the same business objective.</p>
            <ul>
              <li>Hands-on client attention</li>
              <li>Original creative production</li>
              <li>Google and Meta expertise</li>
              <li>Transparent monthly reporting</li>
              <li>Brand-to-search execution</li>
            </ul>
          </div>
          <a href="/contact/#consultation-form">Free Consultation <span aria-hidden="true">↗</span></a>
        </article>
      </div>
    </section>

    <section class="projectShowcase" id="projects" aria-labelledby="projects-title">
      <header class="projectHeader">
        <div>
          <div class="eyebrow" data-reveal="line">Case Studies</div>
          <h2 id="projects-title" data-reveal="title">Our projects that showcase real<br /><span>marketing success.</span></h2>
        </div>
        <div class="projectHeaderAction" data-reveal="up">
          <a class="gradientButton magnetic" href="/case-studies/">View All Projects <b>↗</b></a>
        </div>
      </header>

      <div class="projectCarousel" data-project-carousel>
        <button class="projectArrow projectArrow--prev" type="button" aria-label="View previous project" data-project-prev><span>←</span></button>
        <div class="projectRail" tabindex="0" aria-label="PrysmNexus case studies" data-project-rail>
          {projectStudies.map((project, index) => (
            <article class="projectCard" data-reveal="up" style={`--project-accent:${project.accent};--reveal-delay:${index * 65}ms`}>
              <a class="projectMedia" href="#contact" aria-label={`Discuss a project like ${project.title}`}>
                <Image src={project.image} alt="" widths={[540, 760, 1040]} sizes="(max-width: 760px) 86vw, 34vw" format="webp" quality={90} loading="lazy" />
                <span class="projectCategory">{project.category}</span>
                <span class="projectOpen" aria-hidden="true">↗</span>
              </a>
              <div class="projectCopy"><div><h3>{project.title}</h3><p>{project.copy}</p></div></div>
            </article>
          ))}
        </div>
        <button class="projectArrow projectArrow--next" type="button" aria-label="View next project" data-project-next><span>→</span></button>
        <div class="projectDots" aria-label="Choose a project">
          {projectStudies.map((project, index) => <button type="button" aria-label={`View ${project.title}`} data-project-dot={index}></button>)}
        </div>
      </div>
    </section>

    <section class="clientMarquee" aria-labelledby="clients-title">
      <div class="clientMarqueeGlow" aria-hidden="true"></div>
      <header class="clientMarqueeHeader">
        <div>
          <div class="eyebrow light" data-reveal="line">Selected Clients</div>
          <h2 id="clients-title" data-reveal="title">Built with brands that<br /><span>care about the details.</span></h2>
        </div>
      </header>
      <div class="clientMarqueeWindow" aria-label="Featured PrysmNexus clients">
        <div class="clientMarqueeTrack">
          {[0, 1].map((set) => (
            <div class="clientMarqueeSet" aria-hidden={set === 1 ? "true" : undefined}>
              {featuredClients.map((client, index) => (
                <article class="clientMarqueeCard" style={`--client-index:${index}`}>
                  <span class={`clientMonogram clientLogo clientLogo--${client.key}`} aria-hidden="true">
                    <Image src={client.image} alt="" widths={[160, 240, 320]} sizes="(max-width: 760px) 82px, 112px" format="webp" quality={92} loading="lazy" />
                  </span>
                  <div><strong>{client.name}</strong><small>{client.category}</small></div>
                  <b aria-hidden="true">↗</b>
                </article>
              ))}
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="workProcess" id="process" aria-labelledby="process-title">
      <Image class="workProcessBg" src={processBackdrop} alt="" widths={[1280, 1920, 2560]} sizes="100vw" format="webp" quality={90} loading="lazy" />
      <div class="workProcessVeil" aria-hidden="true"></div>
      <header class="workProcessHeader">
        <div class="eyebrow" data-reveal="line">Work Process</div>
        <h2 id="process-title" data-reveal="title">Our proven process for consistent<br />marketing success.</h2>
      </header>
      <div class="workProcessSteps">
        {workProcessSteps.map((step, index) => (
          <article class="workProcessStep" data-reveal="up" style={`--reveal-delay:${index * 95}ms`}>
            <span class="workProcessIcon" aria-hidden="true"><b>{step.glyph}</b></span>
            <div class="workProcessName"><h3>{step.title}</h3><strong>{step.number}</strong></div>
            <span class="workProcessLine" aria-hidden="true"><i></i></span>
            <p>{step.copy}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="faq faqEditorial" id="faq">
      <div class="faqShell">
        <header class="faqIntro">
          <div class="eyebrow light" data-reveal="line">Frequently Asked Questions</div>
          <h2 data-reveal="title">A few things worth knowing.</h2>
          <p data-reveal="up">Clear answers about scope, content, advertising, visibility, and measurement.</p>
          <a href={`mailto:${seoBrand.email}`} data-reveal="up">Ask us directly <span aria-hidden="true">↗</span></a>
        </header>
        <div class="faqGrid">{faqs.map(({ question, answer }, index) => <details open={index === 0} data-reveal="up" style={`--reveal-delay:${(index % 3) * 60}ms`}><summary>{question}<span aria-hidden="true"></span></summary><div class="faqAnswer"><p>{answer}</p></div></details>)}</div>
      </div>
    </section>

    <footer class="editorialFooter proFooter" id="contact">
      <div class="proFooterGlow" aria-hidden="true"></div>
      <div class="proFooterShell">
        <section class="proFooterCta" aria-labelledby="footer-heading">
          <div class="proFooterIntro">
            <div class="eyebrow light" data-reveal="line">Start a Conversation</div>
            <h2 id="footer-heading" data-reveal="title">One accountable team.<br /><span>Your next stage of growth.</span></h2>
            <p data-reveal="up">Bring your brand, content, campaigns, and search presence into one clear growth system.</p>
          </div>
          <a class="proFooterAction magnetic" href="/contact/#consultation-form" data-reveal="up"><span><small>Let’s discuss your goals</small>Book a free consultation</span><b aria-hidden="true">↗</b></a>
        </section>

        <div class="proFooterRule" aria-hidden="true"><span></span></div>

        <div class="proFooterGrid" data-reveal="up">
          <div class="proFooterBrand">
            <a class="logo inverse" href="#home" translate="no"><span class="brandLogo"><Image src={prysmNexusLogo} alt="" widths={[96, 144, 192, 256]} sizes="62px" format="webp" quality={100} loading="lazy" /></span><span><b>Prysm<span>Nexus</span></b><small>GROWTH MARKETING</small></span></a>
            <p>Strategy, creative, performance, and discovery—managed by one focused team serving businesses across India.</p>
            <span class="proFooterLocation"><i></i>Serving India</span>
          </div>

          <nav class="proFooterLinks" aria-label="Footer navigation">
            <h3>Explore</h3>
            <a href="#home">Home <span>↗</span></a>
            <a href="/about/">About <span>↗</span></a>
            <a href="#projects">Our Works <span>↗</span></a>
            <a href="#process">Process <span>↗</span></a>
          </nav>

          <nav class="proFooterLinks" aria-label="Service navigation">
            <h3>Capabilities</h3>
            <a href="/services/brand-strategy/">Brand Strategy <span>↗</span></a>
            <a href="/services/content-production/">Content Production <span>↗</span></a>
            <a href="/services/performance-marketing/">Performance Marketing <span>↗</span></a>
            <a href="/services/seo-local-search-reputation/">Search & Reputation <span>↗</span></a>
            <a href="/services/ai-automation-systems/">AI Automation <span>↗</span></a>
            <a href="/services/brand-pr-authority/">Brand & PR Authority <span>↗</span></a>
            <a href="/services/custom-software-saas/">Custom Software & SaaS <span>↗</span></a>
          </nav>

          <div class="proFooterContact">
            <h3>Contact</h3>
            <p>Have a project in mind?</p>
            <a href={`mailto:${seoBrand.email}`}>{seoBrand.email} <span>↗</span></a>
            <small>Replies within one business day.</small>
          </div>
        </div>

        <div class="proFooterBottom"><small>© 2026 PrysmNexus. All rights reserved.</small><a href="#home">Back to top <span>↑</span></a></div>
      </div>
    </footer>
  </main>

  <script>
    const root = document.documentElement;
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    const getMotionRate = () => Number.parseFloat(getComputedStyle(root).getPropertyValue("--motion-rate")) || 1;
    root.classList.add("motion-ready");

    const menuButton = document.querySelector<HTMLButtonElement>(".menuButton");
    const nav = document.querySelector<HTMLElement>("#primary-nav");
    const mobileNavBackdrop = document.querySelector<HTMLElement>(".mobileNavBackdrop");
    const setMenuOpen = (open: boolean, restoreFocus = false) => {
      menuButton?.setAttribute("aria-expanded", String(open));
      menuButton?.setAttribute("aria-label", open ? "Close navigation" : "Open navigation");
      nav?.classList.toggle("open", open);
      mobileNavBackdrop?.classList.toggle("is-visible", open);
      document.body.classList.toggle("menu-open", open);
      if (restoreFocus) menuButton?.focus();
    };
    menuButton?.addEventListener("click", () => {
      const expanded = menuButton.getAttribute("aria-expanded") === "true";
      setMenuOpen(!expanded);
    });
    mobileNavBackdrop?.addEventListener("click", () => setMenuOpen(false, true));
    nav?.querySelectorAll("a").forEach((link) => link.addEventListener("click", () => {
      setMenuOpen(false);
    }));
    document.addEventListener("keydown", (event) => {
      if (event.key !== "Escape" || !nav?.classList.contains("open")) return;
      setMenuOpen(false, true);
    });
    window.addEventListener("resize", () => {
      if (window.innerWidth > 760 && nav?.classList.contains("open")) setMenuOpen(false);
    }, { passive: true });

    const smoothSpring = (t: number, b: number, c: number, d: number) => {
      const p = .9;
      const a = 2;
      return c * (1 - Math.exp(-p * t / d)) * Math.sin(a * p * t / d) + b;
    };

    // Advanced reveal system with multiple animation types
    class RevealSystem {
      constructor() {
        this.init();
      }

      init() {
        const revealItems = document.querySelectorAll<HTMLElement>("[data-reveal]");
        if (!revealItems.length) return;

        // Never leave content above the current viewport hidden (for example
        // after refresh, browser scroll restoration, or zoom changes).
        revealItems.forEach((item) => {
          const bounds = item.getBoundingClientRect();
          if (bounds.top <= innerHeight * .92) {
            item.classList.add("reveal-active", "is-visible");
            item.querySelectorAll<HTMLElement>("[data-count]").forEach((counter) => this.animateCounter(counter));
            if (item.matches("[data-count]")) this.animateCounter(item);
          } else {
            item.classList.add("reveal-pending");
          }
        });

        if (reduceMotion.matches || !("IntersectionObserver" in window)) {
          revealItems.forEach((item) => {
            item.classList.remove("reveal-pending");
            item.classList.add("reveal-active", "is-visible");
            item.querySelectorAll<HTMLElement>("[data-count]").forEach((counter) => this.animateCounter(counter));
          });
          return;
        }

        // Stagger calculator for rhythmic reveals
        const calculateStagger = (item: HTMLElement, index: number): number => {
          const baseDelay = 36;
          const revealType = item.dataset.reveal;
          const typeVariation = {
            'up': .8, 'title': 1.2, 'clip': 1, 'line': .6, 'row': 1.1
          };
          const rhythm = typeVariation[revealType as keyof typeof typeVariation] || 1;
          
          // Calculate distance-based staggering for organic rhythm
          const distance = item.getBoundingClientRect().top;
          const viewportHeight = window.innerHeight;
          const proximityFactor = Math.max(0, 1 - distance / (viewportHeight + 200));
          
          const authoredDelay = Number.parseFloat(item.style.getPropertyValue("--reveal-delay")) || 0;
          return Math.min(360, baseDelay + authoredDelay * .34 + (index * 46 * rhythm) + (proximityFactor * 36));
        };

        // Group reveals by type for optimized observation
        const groupedElements = new Map<string, HTMLElement[]>();
        revealItems.forEach((item) => {
          const type = item.dataset.reveal || 'default';
          if (!groupedElements.has(type)) {
            groupedElements.set(type, []);
          }
          groupedElements.get(type)?.push(item);
        });

        groupedElements.forEach((elements, type) => {
          // Different observers for different types with custom thresholds
          const threshold = type === 'title' ? 0.08 : type === 'clip' ? 0.12 : 0.14;
          const observer = new IntersectionObserver((entries, obs) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              const item = entry.target as HTMLElement;
              const staggerDelay = calculateStagger(item, Array.from(groupedElements.get(type) || []).indexOf(item));
              item.style.setProperty('--reveal-delay', `${staggerDelay}ms`);
              item.style.setProperty('--reveal-duration', `${Math.round(580 / getMotionRate())}ms`);
              item.classList.remove("reveal-pending");
              item.classList.add("reveal-active", "is-visible");

              item.querySelectorAll<HTMLElement>("[data-count]").forEach((counter) => this.animateCounter(counter));
              if (item.matches("[data-count]")) this.animateCounter(item);

              item.querySelectorAll<HTMLElement>(".reveal-child").forEach((child, childIndex) => {
                child.style.setProperty("--child-delay", `${staggerDelay + childIndex * 60}ms`);
                child.classList.add("reveal-active");
              });
              obs.unobserve(item);
            });
          }, { threshold, rootMargin: "0px 0px -9%" });
          
          elements.forEach((element) => observer.observe(element));
        });

        // A direct anchor jump can place the start of a section in view while
        // its lower cards sit just outside an item observer threshold. Reveal
        // that section as a compact sequence so it never looks partially empty.
        const sectionObserver = new IntersectionObserver((entries, obs) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const pendingItems = Array.from(entry.target.querySelectorAll<HTMLElement>("[data-reveal].reveal-pending"));
            pendingItems.forEach((item, index) => {
              item.style.setProperty("--reveal-delay", `${32 + index * 38}ms`);
              item.style.setProperty("--reveal-duration", `${Math.round(580 / getMotionRate())}ms`);
              item.classList.remove("reveal-pending");
              item.classList.add("reveal-active", "is-visible");
              item.querySelectorAll<HTMLElement>("[data-count]").forEach((counter) => this.animateCounter(counter));
            });
            obs.unobserve(entry.target);
          });
        }, { threshold: .08, rootMargin: "0px 0px -8%" });
        document.querySelectorAll<HTMLElement>("main > section, main > footer").forEach((section) => sectionObserver.observe(section));
      }

      animateCounter(counter: HTMLElement) {
        if (counter.dataset.counted === "true") return;
        counter.dataset.counted = "true";
        const target = Number(counter.dataset.count ?? "0");
        const started = performance.now();
        const duration = Math.round(680 / getMotionRate());
        const startValue = Number(counter.textContent?.match(/\d+/)?.[0] || "0");
        
        const tick = (now: number) => {
          const progress = Math.min((now - started) / duration, 1);
          const eased = smoothSpring(progress, startValue, target - startValue, 1);
          counter.textContent = `${new Intl.NumberFormat(document.documentElement.lang || "en").format(Math.round(eased))}${counter.dataset.suffix ?? ""}`;
          if (progress < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      }
    }

    // Initialize the advanced reveal system
    const revealSystem = new RevealSystem();

    // Recheck visibility after zoom, resize, anchor navigation, font loading,
    // and browser scroll restoration. Readable content must never remain masked.
    const refreshRevealVisibility = () => {
      document.querySelectorAll<HTMLElement>("[data-reveal].reveal-pending").forEach((item) => {
        const bounds = item.getBoundingClientRect();
        if (bounds.top > innerHeight + 80 || bounds.bottom < -80) return;
        item.classList.remove("reveal-pending");
        item.classList.add("reveal-active", "is-visible");
        item.querySelectorAll<HTMLElement>("[data-count]").forEach((counter) => revealSystem.animateCounter(counter));
        if (item.matches("[data-count]")) revealSystem.animateCounter(item);
      });
    };
    let revealRefreshFrame = 0;
    const scheduleRevealRefresh = () => {
      cancelAnimationFrame(revealRefreshFrame);
      revealRefreshFrame = requestAnimationFrame(refreshRevealVisibility);
    };
    addEventListener("resize", scheduleRevealRefresh, { passive: true });
    addEventListener("hashchange", scheduleRevealRefresh);
    addEventListener("pageshow", scheduleRevealRefresh);
    document.fonts.ready.then(scheduleRevealRefresh);

    // Velocity-aware scroll motion: decorative motion moves faster while the
    // page is in motion, then returns smoothly to its calm base state.
    const progressBar = document.querySelector<HTMLElement>(".scrollProgress span");
    const header = document.querySelector<HTMLElement>("[data-site-header]");
    const glassLayer = document.querySelector<HTMLElement>(".glassLayer");
    const navLinks = document.querySelectorAll<HTMLElement>("#primary-nav a");
    const motionSurfaces = Array.from(document.querySelectorAll<HTMLElement>(
      ".capabilityShowcase, .about, .servicesShowcase, .whyChoose, .projectShowcase, .clientMarquee, .workProcess, .faqEditorial, .proFooter"
    ));
    const visibleMotionSurfaces = new Set<HTMLElement>(motionSurfaces);
    let scrollFrame = 0;
    let lastScrollY = scrollY;
    let lastScrollTime = performance.now();
    let scrollEnergy = 0;
    let motionRate = 1;
    let motionFrame = 0;
    let appliedMotionRate = 0;

    const applyMotionRate = (rate: number) => {
      if (reduceMotion.matches) return;
      if (Math.abs(rate - appliedMotionRate) < .015) return;
      appliedMotionRate = rate;
      motionSurfaces.forEach((surface) => {
        const playbackRate = visibleMotionSurfaces.has(surface) ? rate : 0;
        surface.getAnimations({ subtree: true }).forEach((animation) => {
          if (animation.playState !== "idle") animation.playbackRate = playbackRate;
        });
      });
    };

    const publishMotionState = () => {
      root.style.setProperty("--scroll-energy", scrollEnergy.toFixed(3));
      root.style.setProperty("--motion-rate", motionRate.toFixed(3));
      root.classList.toggle("is-scrolling", scrollEnergy > .05);
      applyMotionRate(motionRate);
    };

    const settleMotion = () => {
      motionFrame = 0;
      scrollEnergy *= .88;
      motionRate += (1 + scrollEnergy * .78 - motionRate) * .22;
      publishMotionState();
      if (scrollEnergy > .008 || Math.abs(motionRate - 1) > .01) {
        motionFrame = requestAnimationFrame(settleMotion);
      } else {
        scrollEnergy = 0;
        motionRate = 1;
        publishMotionState();
      }
    };

    if (!reduceMotion.matches && "IntersectionObserver" in window) {
      const motionObserver = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          const surface = entry.target as HTMLElement;
          if (entry.isIntersecting) visibleMotionSurfaces.add(surface);
          else visibleMotionSurfaces.delete(surface);
        });
        applyMotionRate(motionRate);
      }, { rootMargin: "18% 0px" });
      motionSurfaces.forEach((surface) => motionObserver.observe(surface));
    }
    
    const updateScrollEffects = () => {
      scrollFrame = 0;
      const maxScroll = document.documentElement.scrollHeight - innerHeight;
      const progress = maxScroll > 0 ? scrollY / maxScroll : 0;
      const now = performance.now();
      const elapsed = Math.max(8, now - lastScrollTime);
      const rawVelocity = Math.min(1, Math.abs(scrollY - lastScrollY) / elapsed / 1.1);
      scrollEnergy = Math.max(rawVelocity, scrollEnergy * .72);
      motionRate += (1 + scrollEnergy * .78 - motionRate) * .32;
      lastScrollY = scrollY;
      lastScrollTime = now;
      publishMotionState();
      if (!motionFrame && !reduceMotion.matches) motionFrame = requestAnimationFrame(settleMotion);
      
      progressBar?.style.setProperty("--scroll-progress", String(progress));
      header?.classList.toggle("is-scrolled", scrollY > 28);
      root.style.setProperty("--hero-scroll", `${Math.min(scrollY * 0.12, 90)}px`);
      
      // The header receives only a restrained response to fast scrolling.
      header?.style.setProperty("--header-scale", String(1 + (scrollY > 50 ? scrollEnergy * .025 : 0)));
      
      // Glass layer opacity based on scroll position
      if (glassLayer) {
        const glassOpacity = Math.min(scrollY / 200, 0.8);
        glassLayer.style.setProperty('--glass-opacity', String(glassOpacity));
      }
      
      // Nav link underline position based on scroll
      const navPositions = Array.from(navLinks).map((link) => {
        const targetSection = link.getAttribute('href');
        if (targetSection?.startsWith('#') && targetSection !== '#home') {
          const targetElement = document.querySelector(targetSection);
          if (targetElement) {
            const rect = targetElement.getBoundingClientRect();
            return Math.max(0, Math.min(100, ((innerHeight - rect.top) / (innerHeight + rect.height)) * 100));
          }
        }
        return 0;
      });
      navLinks.forEach((link, index) => link.style.setProperty('--nav-indicator', `${navPositions[index]}%`));
    };
    
    addEventListener("scroll", () => {
      if (!scrollFrame) scrollFrame = requestAnimationFrame(updateScrollEffects);
    }, { passive: true });
    reduceMotion.addEventListener("change", () => {
      if (reduceMotion.matches) {
        scrollEnergy = 0;
        motionRate = 1;
        root.style.setProperty("--scroll-energy", "0");
        root.style.setProperty("--motion-rate", "1");
        root.classList.remove("is-scrolling");
      }
    });
    updateScrollEffects();

    const missionContent = [
      ["Our mission is to give every client hands-on attention, original creative work, and marketing built around what genuinely grows the business."],
      ["Our vision is to help ambitious businesses look sharp, sound clear, and get noticed through connected brand, content, campaign, and search execution."],
      ["Our goal is to replace scattered marketing activity with one focused plan, accountable delivery, useful reporting, and continuous improvement."],
    ];
    const missionTabs = document.querySelectorAll<HTMLButtonElement>("[data-mission-tab]");
    const missionCopy = document.querySelector<HTMLElement>("[data-mission-copy]");
    const activateMissionTab = (tab: HTMLButtonElement) => {
      const index = Number(tab.dataset.missionTab ?? 0);
      missionTabs.forEach((item) => {
        const active = item === tab;
        item.classList.toggle("active", active);
        item.setAttribute("aria-selected", String(active));
        item.tabIndex = active ? 0 : -1;
      });
      if (!missionCopy) return;
      missionCopy.setAttribute("aria-labelledby", tab.id);
      const swap = () => {
        missionCopy.innerHTML = missionContent[index].map((paragraph) => `<p>${paragraph}</p>`).join("");
      };
      if (reduceMotion.matches) return swap();
      missionCopy.animate([{ opacity: 1, transform: "translateY(0)" }, { opacity: 0, transform: "translateY(-8px)" }], { duration: Math.round(130 / getMotionRate()), fill: "forwards" }).finished.then(() => {
        swap();
        missionCopy.animate([{ opacity: 0, transform: "translateY(10px)" }, { opacity: 1, transform: "translateY(0)" }], { duration: Math.round(320 / getMotionRate()), easing: "cubic-bezier(.16,1,.3,1)", fill: "forwards" });
      }).catch(swap);
    };

    missionTabs.forEach((tab, tabIndex) => {
      tab.addEventListener("click", () => activateMissionTab(tab));
      tab.addEventListener("keydown", (event) => {
        if (!["ArrowLeft", "ArrowRight", "Home", "End"].includes(event.key)) return;
        event.preventDefault();
        const lastIndex = missionTabs.length - 1;
        const nextIndex = event.key === "Home" ? 0 : event.key === "End" ? lastIndex : event.key === "ArrowRight" ? (tabIndex + 1) % missionTabs.length : (tabIndex - 1 + missionTabs.length) % missionTabs.length;
        const nextTab = missionTabs[nextIndex];
        nextTab?.focus();
        if (nextTab) activateMissionTab(nextTab);
      });
    });

    document.querySelectorAll<HTMLDetailsElement>(".faq details").forEach((details) => {
      const summary = details.querySelector("summary");
      const answer = details.querySelector<HTMLElement>(".faqAnswer");
      summary?.addEventListener("keydown", (event) => {
        if (event.key !== "Enter" && event.key !== " ") return;
        event.preventDefault();
        summary.click();
      });
      summary?.addEventListener("click", (event) => {
        if (reduceMotion.matches || !answer) return;
        event.preventDefault();
        if (details.open) {
          const animation = answer.animate([{ height: `${answer.offsetHeight}px`, opacity: 1 }, { height: "0px", opacity: 0 }], { duration: Math.round(240 / getMotionRate()), easing: "cubic-bezier(.4,0,.2,1)" });
          animation.onfinish = () => { details.open = false; answer.style.removeProperty("height"); };
        } else {
          details.open = true;
          const height = answer.offsetHeight;
          answer.animate([{ height: "0px", opacity: 0 }, { height: `${height}px`, opacity: 1 }], { duration: Math.round(330 / getMotionRate()), easing: "cubic-bezier(.16,1,.3,1)" }).onfinish = () => answer.style.removeProperty("height");
        }
      });
    });

    const projectRail = document.querySelector<HTMLElement>("[data-project-rail]");
    const projectPrevious = document.querySelector<HTMLButtonElement>("[data-project-prev]");
    const projectNext = document.querySelector<HTMLButtonElement>("[data-project-next]");
    const projectDots = document.querySelectorAll<HTMLButtonElement>("[data-project-dot]");
    const projectCarousel = document.querySelector<HTMLElement>("[data-project-carousel]");
    if (projectRail && projectPrevious && projectNext && projectCarousel && projectDots.length) {
      const projectStep = () => {
        const card = projectRail.querySelector<HTMLElement>(".projectCard");
        const gap = Number.parseFloat(getComputedStyle(projectRail).columnGap || "0");
        return (card?.offsetWidth ?? projectRail.clientWidth * .85) + gap;
      };
      const updateProjectCarousel = () => {
        const maximum = Math.max(1, projectRail.scrollWidth - projectRail.clientWidth);
        const activeIndex = Math.min(projectDots.length - 1, Math.max(0, Math.round(projectRail.scrollLeft / projectStep())));
        projectDots.forEach((dot, index) => {
          const active = index === activeIndex;
          dot.classList.toggle("active", active);
          dot.setAttribute("aria-current", active ? "true" : "false");
        });
        projectPrevious.disabled = projectRail.scrollLeft <= 4;
        projectNext.disabled = projectRail.scrollLeft >= maximum - 4;
      };
      projectPrevious.addEventListener("click", () => projectRail.scrollBy({ left: -projectStep(), behavior: reduceMotion.matches ? "auto" : "smooth" }));
      projectNext.addEventListener("click", () => projectRail.scrollBy({ left: projectStep(), behavior: reduceMotion.matches ? "auto" : "smooth" }));
      projectDots.forEach((dot, index) => dot.addEventListener("click", () => projectRail.scrollTo({ left: index * projectStep(), behavior: reduceMotion.matches ? "auto" : "smooth" })));
      projectRail.addEventListener("keydown", (event) => {
        if (event.key !== "ArrowLeft" && event.key !== "ArrowRight") return;
        event.preventDefault();
        projectRail.scrollBy({ left: event.key === "ArrowRight" ? projectStep() : -projectStep(), behavior: reduceMotion.matches ? "auto" : "smooth" });
      });
      let projectScrollFrame = 0;
      projectRail.addEventListener("scroll", () => {
        cancelAnimationFrame(projectScrollFrame);
        projectScrollFrame = requestAnimationFrame(updateProjectCarousel);
      }, { passive: true });
      let dragStart = 0;
      let dragScrollStart = 0;
      let dragging = false;
      let suppressProjectClick = false;
      projectRail.addEventListener("pointerdown", (event) => {
        if (event.pointerType !== "mouse") return;
        dragging = true;
        suppressProjectClick = false;
        dragStart = event.clientX;
        dragScrollStart = projectRail.scrollLeft;
        projectRail.classList.add("is-dragging");
        projectRail.setPointerCapture(event.pointerId);
      });
      projectRail.addEventListener("pointermove", (event) => {
        if (!dragging) return;
        const distance = event.clientX - dragStart;
        if (Math.abs(distance) > 5) suppressProjectClick = true;
        projectRail.scrollLeft = dragScrollStart - distance;
      });
      const stopProjectDrag = (event: PointerEvent) => {
        if (!dragging) return;
        dragging = false;
        projectRail.classList.remove("is-dragging");
        if (projectRail.hasPointerCapture(event.pointerId)) projectRail.releasePointerCapture(event.pointerId);
      };
      projectRail.addEventListener("pointerup", stopProjectDrag);
      projectRail.addEventListener("pointercancel", stopProjectDrag);
      projectRail.addEventListener("click", (event) => {
        if (!suppressProjectClick) return;
        event.preventDefault();
        suppressProjectClick = false;
      }, true);
      let projectAutoTimer = 0;
      const stopProjectAuto = () => window.clearInterval(projectAutoTimer);
      const startProjectAuto = () => {
        stopProjectAuto();
        if (reduceMotion.matches || document.hidden) return;
        projectAutoTimer = window.setInterval(() => {
          const maximum = projectRail.scrollWidth - projectRail.clientWidth;
          const atEnd = projectRail.scrollLeft >= maximum - projectStep() * .3;
          projectRail.scrollTo({ left: atEnd ? 0 : projectRail.scrollLeft + projectStep(), behavior: "smooth" });
        }, 3600);
      };
      projectCarousel.addEventListener("pointerenter", stopProjectAuto);
      projectCarousel.addEventListener("pointerleave", startProjectAuto);
      projectCarousel.addEventListener("focusin", stopProjectAuto);
      projectCarousel.addEventListener("focusout", startProjectAuto);
      document.addEventListener("visibilitychange", () => document.hidden ? stopProjectAuto() : startProjectAuto());
      new ResizeObserver(updateProjectCarousel).observe(projectRail);
      updateProjectCarousel();
      startProjectAuto();
    }

    const finePointer = window.matchMedia("(pointer: fine)");
    const halo = document.querySelector<HTMLElement>(".cursorHalo");
    if (finePointer.matches && !reduceMotion.matches) {
      addEventListener("pointermove", (event) => {
        halo?.style.setProperty("--pointer-x", `${event.clientX}px`);
        halo?.style.setProperty("--pointer-y", `${event.clientY}px`);
        halo?.classList.add("is-active");
      }, { passive: true });
      document.querySelectorAll<HTMLElement>(".magnetic").forEach((element) => {
        element.addEventListener("pointermove", (event) => {
          const rect = element.getBoundingClientRect();
          element.style.setProperty("--magnet-x", `${(event.clientX - rect.left - rect.width / 2) * 0.12}px`);
          element.style.setProperty("--magnet-y", `${(event.clientY - rect.top - rect.height / 2) * 0.12}px`);
        });
        element.addEventListener("pointerleave", () => {
          element.style.setProperty("--magnet-x", "0px");
          element.style.setProperty("--magnet-y", "0px");
        });
      });
    const hero = document.querySelector<HTMLElement>(".hero");
    const heroPortrait = document.querySelector<HTMLElement>(".heroPortrait");
    const heroGlow = document.querySelector<HTMLElement>(".heroGlow");
    const heroCopy = document.querySelector<HTMLElement>(".heroCopy");
    
    if (hero && !reduceMotion.matches) {
      hero.addEventListener("pointermove", (event) => {
        const x = event.clientX / innerWidth - .5;
        const y = event.clientY / innerHeight - .5;
        const intensity = Math.sqrt(x * x + y * y);
        
        hero.style.setProperty("--pointer-shift-x", `${x * 18 * intensity}px`);
        hero.style.setProperty("--pointer-shift-y", `${y * 12 * intensity}px`);
        
        if (heroPortrait) {
          heroPortrait.style.setProperty("--portrait-tilt", `${-y * 8}deg`);
          heroPortrait.style.setProperty("--portrait-scale", `${1 + intensity * .02}`);
        }
        
        if (heroGlow) {
          heroGlow.style.setProperty("--glow-intensity", `${intensity * .6}`);
          heroGlow.style.setProperty("--glow-x", `${x * 50}%`);
          heroGlow.style.setProperty("--glow-y", `${y * 50}%`);
        }
      }, { passive: true });
      
      if (heroCopy) {
        heroCopy.addEventListener("pointermove", (event) => {
          const rect = heroCopy.getBoundingClientRect();
          const x = (event.clientX - rect.left) / rect.width - .5;
          const y = (event.clientY - rect.top) / rect.height - .5;
          heroCopy.style.setProperty("--copy-shift-x", `${x * 5}px`);
          heroCopy.style.setProperty("--copy-shift-y", `${y * 5}px`);
        }, { passive: true });
      }
    }
    }

    const canvas = document.querySelector<HTMLCanvasElement>(".prismCanvas");
    const prismHero = document.querySelector<HTMLElement>(".hero");
    if (canvas && prismHero) {
      const gl = canvas.getContext("webgl2", {
        alpha: true,
        antialias: true,
        depth: false,
        powerPreference: "high-performance",
        premultipliedAlpha: false,
      });

      if (!gl) {
        canvas.hidden = true;
      } else {
        const vertexSource = `#version 300 es
          in vec2 aPosition;
          void main() { gl_Position = vec4(aPosition, 0.0, 1.0); }
        `;
        const fragmentSource = `#version 300 es
          precision highp float;
          out vec4 outColor;
          uniform vec2 uResolution;
          uniform vec3 uAssembly;
          uniform float uReflection;
          uniform vec2 uPointer;
          uniform vec2 uAnchor;

          mat2 rotate2d(float angle) {
            float c = cos(angle), s = sin(angle);
            return mat2(c, -s, s, c);
          }

          float triangleDistance(vec2 p, vec2 a, vec2 b, vec2 c) {
            vec2 e0 = b - a;
            vec2 e1 = c - b;
            vec2 e2 = a - c;
            vec2 v0 = p - a;
            vec2 v1 = p - b;
            vec2 v2 = p - c;
            vec2 pq0 = v0 - e0 * clamp(dot(v0, e0) / dot(e0, e0), 0.0, 1.0);
            vec2 pq1 = v1 - e1 * clamp(dot(v1, e1) / dot(e1, e1), 0.0, 1.0);
            vec2 pq2 = v2 - e2 * clamp(dot(v2, e2) / dot(e2, e2), 0.0, 1.0);
            float orientation = sign(e0.x * e2.y - e0.y * e2.x);
            vec2 distanceEdge = min(
              min(vec2(dot(pq0, pq0), orientation * (v0.x * e0.y - v0.y * e0.x)),
                  vec2(dot(pq1, pq1), orientation * (v1.x * e1.y - v1.y * e1.x))),
              vec2(dot(pq2, pq2), orientation * (v2.x * e2.y - v2.y * e2.x))
            );
            return -sqrt(distanceEdge.x) * sign(distanceEdge.y);
          }

          float triangularCard(vec3 p) {
            float face = triangleDistance(
              p.xy,
              vec2(-.78, .01),
              vec2(.78, .01),
              vec2(0.0, -.44)
            );
            vec2 extrusion = vec2(face, abs(p.z) - .052);
            return min(max(extrusion.x, extrusion.y), 0.0)
              + length(max(extrusion, 0.0)) - .018;
          }

          float panelDistance(vec3 p, float angle, float assembled, vec3 origin, float twist) {
            vec3 q = p - origin * (1.0 - assembled);
            q.xy *= rotate2d(angle + (1.0 - assembled) * twist);
            q.y -= .44;
            q.z += (1.0 - assembled) * origin.z * .22;
            return triangularCard(q);
          }

          vec2 scene(vec3 p) {
            // Enlarge the complete prism without changing the three-panel
            // geometry, assembly timing, pointer response, or screen anchor.
            const float prismScale = 1.18;
            p /= prismScale;

            float first = uAssembly.x;
            float second = uAssembly.y;
            float third = uAssembly.z;
            float frontPose = smoothstep(.86, .995, min(first, min(second, third)));

            float faceRotation = mix(-.12, -.08, frontPose);
            float depthTilt = 1.0 - frontPose;
            p.xy *= rotate2d(faceRotation);
            p.yz *= rotate2d(.69 * depthTilt);
            p.xz *= rotate2d(-.38 * depthTilt);
            p.yz *= rotate2d(uPointer.y * .18 * frontPose);
            p.xz *= rotate2d(-uPointer.x * .22 * frontPose);

            float aspectRatio = uResolution.x / uResolution.y;
            float horizontalEdge = mix(2.9, 5.05, smoothstep(.72, 1.78, aspectRatio));
            float lowerEdge = mix(3.35, 3.75, smoothstep(.72, 1.45, aspectRatio));
            float d1 = panelDistance(p, 0.0, first, vec3(-horizontalEdge, .34, .9), -.72);
            float d2 = panelDistance(p, 2.094395, second, vec3(horizontalEdge, .34, -.75), .84);
            float d3 = panelDistance(p, 4.188790, third, vec3(0.0, -lowerEdge, 1.05), -.96);
            vec2 result = vec2(d1, 1.0);
            if (d2 < result.x) result = vec2(d2, 2.0);
            if (d3 < result.x) result = vec2(d3, 3.0);
            result.x *= prismScale;
            return result;
          }

          vec3 normalAt(vec3 p) {
            vec2 e = vec2(.0015, 0.0);
            return normalize(vec3(
              scene(p + e.xyy).x - scene(p - e.xyy).x,
              scene(p + e.yxy).x - scene(p - e.yxy).x,
              scene(p + e.yyx).x - scene(p - e.yyx).x
            ));
          }

          void main() {
            vec2 uv = (gl_FragCoord.xy * 2.0 - uResolution.xy) / min(uResolution.x, uResolution.y);
            uv -= uAnchor;

            vec3 rayOrigin = vec3(uPointer.x * .11, -uPointer.y * .075, 4.35);
            vec3 rayDirection = normalize(vec3(uv - uPointer * .028, -2.28));
            float travel = 0.0;
            float nearest = 8.0;
            float material = 1.0;
            bool hit = false;

            for (int step = 0; step < 84; step++) {
              vec3 point = rayOrigin + rayDirection * travel;
              vec2 samplePoint = scene(point);
              float distanceToSurface = samplePoint.x;
              nearest = min(nearest, abs(distanceToSurface));
              if (distanceToSurface < .0012) { hit = true; material = samplePoint.y; break; }
              travel += distanceToSurface * .72;
              if (travel > 8.0) break;
            }

            float aura = exp(-10.5 * nearest) * .18;
            vec3 auraColor = mix(vec3(.88, .015, .035), vec3(1.0, .19, .24), .72);
            if (!hit) {
              float pixelFootprint = 2.0 / min(uResolution.x, uResolution.y);
              float edgeCoverage = 1.0 - smoothstep(
                .0012,
                .0012 + pixelFootprint * 1.35,
                nearest
              );
              outColor = vec4(auraColor, max(aura, edgeCoverage * .92));
              return;
            }

            vec3 point = rayOrigin + rayDirection * travel;
            vec3 normal = normalAt(point);
            vec3 lightDirection = normalize(vec3(
              -.45 + uPointer.x * .48,
              .8 - uPointer.y * .34,
              1.15
            ));
            vec3 rimDirection = normalize(vec3(.8, -.25, .55));
            float diffuse = max(dot(normal, lightDirection), 0.0);
            float rim = pow(1.0 - max(dot(normal, -rayDirection), 0.0), 2.5);
            float edge = pow(max(dot(normal, rimDirection), 0.0), 5.0);
            float faceTone = smoothstep(-.7, .9, normal.x * .65 + normal.y * .35);

            vec3 panelRed = mix(vec3(.42, .004, .015), vec3(1.0, .025, .045), faceTone);
            vec3 panelCoral = mix(vec3(.35, .008, .018), vec3(1.0, .18, .21), faceTone);
            vec3 panelGraphite = mix(vec3(.025, .03, .04), vec3(.18, .21, .25), faceTone);
            vec3 color = material < 1.5 ? panelRed : (material < 2.5 ? panelCoral : panelGraphite);
            color *= .42 + diffuse * .92;
            color += vec3(1.0, .12, .16) * (rim * .62 + edge * .78);
            color += vec3(1.0, .8, .78) * pow(max(dot(reflect(rayDirection, normal), lightDirection), 0.0), 42.0) * .9;

            float joined = smoothstep(.94, .998, min(uAssembly.x, min(uAssembly.y, uAssembly.z)));
            float sweepProgress = clamp(uReflection, 0.0, 1.0);
            float sweepStrength = sin(sweepProgress * 3.14159265);
            float sweepPosition = mix(-1.05, 1.05, sweepProgress);
            float reflectionBand = exp(-54.0 * pow((uv.x + uv.y * .42) - sweepPosition, 2.0));
            float polishedSpecular = pow(max(dot(reflect(rayDirection, normal), normalize(vec3(-.72, .52, 1.0))), 0.0), 18.0);
            float joiningReflection = joined * sweepStrength * (reflectionBand * 1.18 + polishedSpecular * .38);
            color += vec3(1.0, .82, .79) * joiningReflection;
            color += auraColor * aura * 1.8;

            outColor = vec4(color, 1.0);
          }
        `;

        const compileShader = (type: number, source: string) => {
          const shader = gl.createShader(type);
          if (!shader) return null;
          gl.shaderSource(shader, source);
          gl.compileShader(shader);
          if (!gl.getShaderParameter(shader, gl.COMPILE_STATUS)) {
            console.warn("Hero prism shader unavailable", gl.getShaderInfoLog(shader));
            gl.deleteShader(shader);
            return null;
          }
          return shader;
        };

        const vertexShader = compileShader(gl.VERTEX_SHADER, vertexSource);
        const fragmentShader = compileShader(gl.FRAGMENT_SHADER, fragmentSource);
        const program = vertexShader && fragmentShader ? gl.createProgram() : null;
        if (!program || !vertexShader || !fragmentShader) {
          canvas.hidden = true;
        } else {
          gl.attachShader(program, vertexShader);
          gl.attachShader(program, fragmentShader);
          gl.linkProgram(program);
          if (!gl.getProgramParameter(program, gl.LINK_STATUS)) {
            console.warn("Hero prism program unavailable", gl.getProgramInfoLog(program));
            canvas.hidden = true;
          } else {
            const vertices = new Float32Array([-1, -1, 3, -1, -1, 3]);
            const buffer = gl.createBuffer();
            gl.bindBuffer(gl.ARRAY_BUFFER, buffer);
            gl.bufferData(gl.ARRAY_BUFFER, vertices, gl.STATIC_DRAW);
            const position = gl.getAttribLocation(program, "aPosition");
            gl.enableVertexAttribArray(position);
            gl.vertexAttribPointer(position, 2, gl.FLOAT, false, 0, 0);
            gl.useProgram(program);

            const resolutionUniform = gl.getUniformLocation(program, "uResolution");
            const assemblyUniform = gl.getUniformLocation(program, "uAssembly");
            const reflectionUniform = gl.getUniformLocation(program, "uReflection");
            const pointerUniform = gl.getUniformLocation(program, "uPointer");
            const anchorUniform = gl.getUniformLocation(program, "uAnchor");
            let width = 0;
            let height = 0;
            let visible = true;
            let frame = 0;
            let scrollFrame = 0;
            let lastPrismScrollY = scrollY;
            let previousFrame = 0;
            let entranceActive = false;
            let entranceStart = 0;
            let reflectionStart = -1;
            let wasJoined = false;
            let destroyed = false;
            let clickSeparated = false;
            let clickSplitTimer = 0;
            const assembly = [1, 1, 1];
            let assemblyTarget = [1, 1, 1];
            const pointer = [0, 0];
            const pointerTarget = [0, 0];
            const prismAnchor = [0, -.015];
            const heroLayout = prismHero.querySelector<HTMLElement>(".heroLayout");

            const clamp01 = (value: number) => Math.min(1, Math.max(0, value));
            const smoothstep = (edge0: number, edge1: number, value: number) => {
              const progress = clamp01((value - edge0) / Math.max(edge1 - edge0, .001));
              return progress * progress * (3 - 2 * progress);
            };
            const easeOutCubic = (value: number) => 1 - Math.pow(1 - clamp01(value), 3);

            const getScrollAssembly = () => {
              if (reduceMotion.matches) return [1, 1, 1];
              if (clickSeparated) return [0, 0, 0];
              const bounds = prismHero.getBoundingClientRect();
              const travelled = Math.max(0, -bounds.top);
              const splitProgress = smoothstep(bounds.height * .08, bounds.height * .68, travelled);
              return [
                1 - smoothstep(0, .78, splitProgress),
                1 - smoothstep(.08, .89, splitProgress),
                1 - smoothstep(.16, 1, splitProgress),
              ];
            };

            const drawPrism = (reflectionProgress = 0) => {
              gl.clearColor(0, 0, 0, 0);
              gl.clear(gl.COLOR_BUFFER_BIT);
              gl.uniform2f(resolutionUniform, canvas.width, canvas.height);
              gl.uniform3f(assemblyUniform, assembly[0], assembly[1], assembly[2]);
              gl.uniform1f(reflectionUniform, reflectionProgress);
              gl.uniform2f(pointerUniform, pointer[0], pointer[1]);
              gl.uniform2f(anchorUniform, prismAnchor[0], prismAnchor[1]);
              gl.drawArrays(gl.TRIANGLES, 0, 3);
            };

            const schedulePrism = () => {
              if (destroyed || frame || !visible) return;
              frame = requestAnimationFrame(renderPrism);
            };

            const updatePrismFromScroll = () => {
              entranceActive = false;
              assemblyTarget = getScrollAssembly();
              schedulePrism();
            };

            const resizePrism = () => {
              // A true 2x backing store keeps the ray-marched silhouette smooth
              // without altering the prism's CSS size or animation geometry.
              const ratio = Math.min(devicePixelRatio || 1, 2);
              width = prismHero.clientWidth;
              height = prismHero.clientHeight;
              const heroBounds = prismHero.getBoundingClientRect();
              const shellBounds = (heroLayout ?? prismHero).getBoundingClientRect();
              const minimumDimension = Math.max(1, Math.min(width, height));
              const targetCenterX = shellBounds.left - heroBounds.left + shellBounds.width * .55;
              prismAnchor[0] = 2 * (targetCenterX - width * .5) / minimumDimension;
              prismAnchor[1] = -.015;
              canvas.width = Math.round(width * ratio);
              canvas.height = Math.round(height * ratio);
              canvas.style.width = `${width}px`;
              canvas.style.height = `${height}px`;
              gl.viewport(0, 0, canvas.width, canvas.height);
              schedulePrism();
            };

            function renderPrism(now: number) {
              frame = 0;
              if (!visible || destroyed) return;
              const delta = previousFrame ? Math.min((now - previousFrame) / 1000, .05) : 1 / 60;
              previousFrame = now;

              let moving = false;
              if (entranceActive && !reduceMotion.matches) {
                const delays = [0, 90, 180];
                for (let index = 0; index < assembly.length; index += 1) {
                  const progress = clamp01((now - entranceStart - delays[index]) / 760);
                  assembly[index] = easeOutCubic(progress);
                  if (progress < 1) moving = true;
                }
                if (!moving) {
                  entranceActive = false;
                  assemblyTarget = getScrollAssembly();
                }
              } else {
                const response = 1 - Math.exp(-delta * 12);
                for (let index = 0; index < assembly.length; index += 1) {
                  const difference = assemblyTarget[index] - assembly[index];
                  if (Math.abs(difference) > .0015) {
                    assembly[index] += difference * response;
                    moving = true;
                  } else {
                    assembly[index] = assemblyTarget[index];
                  }
                }
              }

              const pointerResponse = 1 - Math.exp(-delta * 10);
              for (let index = 0; index < pointer.length; index += 1) {
                const difference = pointerTarget[index] - pointer[index];
                if (Math.abs(difference) > .001) {
                  pointer[index] += difference * pointerResponse;
                  moving = true;
                } else {
                  pointer[index] = pointerTarget[index];
                }
              }

              const joined = assembly.every((value) => value > .997) && assemblyTarget.every((value) => value > .997);
              if (joined && !wasJoined && !reduceMotion.matches) reflectionStart = now;
              wasJoined = joined;

              let reflectionProgress = 0;
              if (reflectionStart >= 0) {
                reflectionProgress = clamp01((now - reflectionStart) / 720);
                if (reflectionProgress < 1) moving = true;
                else reflectionStart = -1;
              }

              drawPrism(reflectionProgress);
              if (entranceActive || moving) schedulePrism();
              else previousFrame = 0;
            }

            new ResizeObserver(resizePrism).observe(prismHero);
            new IntersectionObserver(([entry]) => {
              visible = entry.isIntersecting && !document.hidden;
              if (visible) {
                assemblyTarget = getScrollAssembly();
                schedulePrism();
              } else if (frame) {
                cancelAnimationFrame(frame);
                frame = 0;
                previousFrame = 0;
              }
            }).observe(prismHero);

            const updatePointerTarget = (event: PointerEvent) => {
              if (reduceMotion.matches || event.pointerType === "touch") return;
              const bounds = prismHero.getBoundingClientRect();
              if (bounds.bottom <= 0 || bounds.top >= innerHeight) return;
              pointerTarget[0] = Math.max(-1, Math.min(1, ((event.clientX - bounds.left) / bounds.width - .5) * 2));
              pointerTarget[1] = Math.max(-1, Math.min(1, ((event.clientY - bounds.top) / bounds.height - .5) * 2));
              schedulePrism();
            };
            const resetPointerTarget = () => {
              pointerTarget[0] = 0;
              pointerTarget[1] = 0;
              schedulePrism();
            };
            addEventListener("pointermove", updatePointerTarget, { passive: true });
            prismHero.addEventListener("pointerleave", resetPointerTarget, { passive: true });

            const splitPrismOnClick = (event: MouseEvent) => {
              if (reduceMotion.matches || clickSeparated || assembly.some((value) => value < .94)) return;
              const target = event.target as Element | null;
              if (target?.closest("a, button, input, select, textarea, label")) return;

              clickSeparated = true;
              entranceActive = false;
              reflectionStart = -1;
              pointerTarget.splice(0, 2, 0, 0);
              assemblyTarget = [0, 0, 0];
              schedulePrism();

              if (clickSplitTimer) clearTimeout(clickSplitTimer);
              clickSplitTimer = window.setTimeout(() => {
                clickSeparated = false;
                assemblyTarget = getScrollAssembly();
                schedulePrism();
              }, 1050);
            };
            prismHero.addEventListener("click", splitPrismOnClick);

            addEventListener("scroll", () => {
              if (scrollFrame) return;
              scrollFrame = requestAnimationFrame(() => {
                scrollFrame = 0;
                if (Math.abs(scrollY - lastPrismScrollY) < .5) return;
                lastPrismScrollY = scrollY;
                updatePrismFromScroll();
              });
            }, { passive: true });

            const restorePrismState = () => {
              assemblyTarget = getScrollAssembly();
              if (reduceMotion.matches) {
                assembly.splice(0, 3, 1, 1, 1);
                pointer.splice(0, 2, 0, 0);
                pointerTarget.splice(0, 2, 0, 0);
                entranceActive = false;
                reflectionStart = -1;
              }
              schedulePrism();
            };

            addEventListener("pageshow", restorePrismState);
            addEventListener("hashchange", restorePrismState);
            reduceMotion.addEventListener("change", restorePrismState);
            document.addEventListener("visibilitychange", () => {
              const bounds = prismHero.getBoundingClientRect();
              visible = !document.hidden && bounds.bottom > 0 && bounds.top < innerHeight;
              if (visible) restorePrismState();
            });

            resizePrism();
            assemblyTarget = getScrollAssembly();
            const startsAtHero = assemblyTarget.every((value) => value > .997) && !reduceMotion.matches;
            if (startsAtHero) {
              assembly.splice(0, 3, 0, 0, 0);
              entranceActive = true;
              entranceStart = performance.now() + 110;
            } else {
              assembly.splice(0, 3, ...assemblyTarget);
              wasJoined = assembly.every((value) => value > .997);
            }
            schedulePrism();
            addEventListener("pagehide", () => {
              destroyed = true;
              if (frame) cancelAnimationFrame(frame);
              if (scrollFrame) cancelAnimationFrame(scrollFrame);
              if (clickSplitTimer) clearTimeout(clickSplitTimer);
            }, { once: true });
          }
        }
      }
    }
  </script>
</BaseLayout>
