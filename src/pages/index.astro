          <div class="proFooterContact">
            <h3>Contact</h3>
            <p>Have a project in mind?</p>
            <a href={`mailto:${seoBrand.email}`}>{seoBrand.email} <span>↗</span></a>
            <a href="tel:+917330662949">+91 73306 62949 <span>↗</span></a>
            <a href="https://www.instagram.com/prysmnexus.agency/" target="_blank" rel="noopener noreferrer" aria-label="PrysmNexus on Instagram">@prysmnexus.agency <span aria-hidden="true"><svg width="17" height="17" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="3" width="18" height="18" rx="5" stroke="currentColor" stroke-width="1.8"/><circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.8"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg></span></a>
