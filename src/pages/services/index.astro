---
import SeoLayout from "../../layouts/SeoLayout.astro";
import { brand, breadcrumbSchema, services } from "../../data/seo";
const origin = (Astro.site ?? new URL(brand.domain)).origin;
const schemas = [breadcrumbSchema(origin, [{ name: "Home", path: "/" }, { name: "Services", path: "/services/" }]), { "@context": "https://schema.org", "@type": "ItemList", name: "PrysmNexus services", itemListElement: services.map((service, index) => ({ "@type": "ListItem", position: index + 1, url: `${origin}/services/${service.slug}/`, name: service.name })) }];
---
<SeoLayout title="Growth Marketing Services in Hyderabad | PrysmNexus" description="Explore PrysmNexus brand strategy, content production, social media, performance marketing, SEO, local search, and reputation services in Hyderabad." eyebrow="Connected growth services" heading="Every service your brand needs. One accountable Hyderabad team." lead="Strategy, original production, publishing, paid acquisition, search visibility, and reputation support work better when they share one clear plan." schemas={schemas}>
  <div class="seoMain">
    <aside class="answerBlock"><span>What PrysmNexus does</span><p>PrysmNexus is a Hyderabad growth marketing agency that connects brand strategy, content production, social media management, Google and Meta advertising, SEO, local search, and reputation support under one coordinated team.</p></aside>
    <section class="seoSection">
      <div class="seoSectionHead"><h2>Five focused service systems.</h2><p>Each page below defines the service, explains the working process, answers common questions, and shows how it connects with the rest of the growth system.</p></div>
      <div class="seoIndexGrid" style="margin-top:38px">{services.map((service, index) => <a class="seoIndexCard" href={`/services/${service.slug}/`}><small>0{index + 1} · {service.eyebrow}</small><div><h2>{service.name}</h2><p>{service.description}</p></div><strong>Explore service ↗</strong></a>)}</div>
    </section>
    <section class="seoSection"><div class="seoSectionHead"><h2>Built around business outcomes.</h2><p>No channel is treated as an isolated task. Brand clarity shapes content. Content strengthens campaigns. Campaign learning improves messaging. Search and reputation make the whole system easier to discover and trust.</p></div></section>
  </div>
</SeoLayout>
